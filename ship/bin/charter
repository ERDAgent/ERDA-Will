#!/usr/bin/env bash
# charter — register a repo as a charter in the fleet
# usage: charter <name> [git-url] [--local]
#   charter royal-guest git@github.com:eric/royal-guest-site.git   # clone an existing repo
#   charter royal-guest                                            # no url: create a new
#                                                                   #   public ERDAgent/royal-guest
#                                                                   #   repo (or use it if it
#                                                                   #   already exists), needs gh
#                                                                   #   authenticated with repo-
#                                                                   #   creation permission
#   charter scratchpad --local                                     # explicitly local-only, no
#                                                                   #   remote at all, empty hold
# CHARTER_VISIBILITY=private|internal overrides the public default for one call.
set -euo pipefail

FLEET="${FLEET:-$HOME/fleet}"
GH_OWNER="${GH_OWNER:-ERDAgent}"
# Default matches ERDA-Will's own visibility; override per-call for a charter
# that must stay private (client work, anything sensitive) --
# CHARTER_VISIBILITY=private charter <name>. gh only accepts these three as
# separate flags (confirmed via `gh repo create --help`), not a single
# --visibility=X value.
CHARTER_VISIBILITY="${CHARTER_VISIBILITY:-public}"
case "$CHARTER_VISIBILITY" in
  public|private|internal) ;;
  *)
    echo "invalid CHARTER_VISIBILITY: '$CHARTER_VISIBILITY' (must be public, private, or internal)" >&2
    exit 1
    ;;
esac

NAME=""
URL=""
LOCAL_ONLY=0
for arg in "$@"; do
  case "$arg" in
    --local) LOCAL_ONLY=1 ;;
    *)
      if [[ -z "$NAME" ]]; then NAME="$arg"
      elif [[ -z "$URL" ]]; then URL="$arg"
      fi
      ;;
  esac
done
[[ -n "$NAME" ]] || { echo "usage: charter <name> [git-url] [--local]" >&2; exit 1; }
DIR="$FLEET/$NAME"

[[ "$NAME" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]] || {
  echo "invalid charter name: '$NAME' (letters, digits, - and _ only)" >&2
  exit 1
}

if [[ -e "$DIR/.hold.git" ]]; then
  echo "charter '$NAME' already exists at $DIR" >&2
  exit 1
fi

# --- no URL given: create (or reuse) a GitHub repo, unless --local ---
# Needs gh authenticated (eval "$(unlock captain)") AND a GH_TOKEN with repo
# *creation* permission -- broader than the Contents-R/W-on-specific-repos
# scope strongbox/README.md documents for push access (D14). Fine-grained
# PATs need "All repositories" access + Administration: Read and write to
# create new repos at all; verified directly that the original push-only
# scope gets "Resource not accessible by personal access token" from `gh
# repo create`. Falls back to a local-only charter rather than failing hard
# -- a charter should still work for an operator without gh set up.
if [[ -z "$URL" && "$LOCAL_ONLY" -eq 0 ]]; then
  # The very first charter on a freshly christened ship always hit this: GH_TOKEN
  # lives in the captain compartment and nothing loads it into a plain shell
  # automatically -- sail's bridge window does its own auto-unlock, but a bare
  # `captain charter` in whatever shell you happen to be in never did. This is
  # the same privilege the bridge already gets for free, not a new escalation,
  # so unlock quietly here too. If ship.key was never deployed to this ship at
  # all (erda open lockbox <ship>), unlock just fails and the check below
  # reports the normal "gh not authenticated" fallback.
  if ! (command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1) && command -v unlock >/dev/null 2>&1; then
    eval "$(unlock captain 2>/dev/null)" 2>/dev/null || true
  fi

  if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
    if gh repo view "$GH_OWNER/$NAME" >/dev/null 2>&1; then
      echo "GitHub repo $GH_OWNER/$NAME already exists -- using it"
      URL="https://github.com/$GH_OWNER/$NAME.git"
    elif gh repo create "$GH_OWNER/$NAME" "--$CHARTER_VISIBILITY" >/dev/null 2>&1; then
      echo "created GitHub repo $GH_OWNER/$NAME ($CHARTER_VISIBILITY)"
      URL="https://github.com/$GH_OWNER/$NAME.git"
    else
      echo "charter: couldn't create $GH_OWNER/$NAME on GitHub -- likely a PAT scope issue" >&2
      echo "  (repo creation needs broader permissions than the default Contents R/W -- see strongbox/README.md)" >&2
      echo "  falling back to a local-only charter" >&2
    fi
  else
    echo "charter: gh not authenticated -- run 'eval \"\$(unlock captain)\"' first if you want an auto-created GitHub repo" >&2
    echo "  falling back to a local-only charter" >&2
  fi
fi

mkdir -p "$DIR"/{berths,.ship/orders,.ship/reports,.ship/reviews,.ship/log}
cd "$DIR"

# --- the hold: bare repo all berths hang off ---
# An empty bare repo (whether git init --bare here, or a freshly
# `gh repo create`d GitHub repo with zero commits -- confirmed this is
# exactly what auto-create above produces) has no commits or branches at
# all, so `worktree add ... main` below would fail with "invalid reference:
# main". Lay the keel with an empty root commit whenever main doesn't exist
# yet, pushing to origin too if there is one, so a freshly auto-created
# GitHub repo isn't left empty either.
lay_the_keel() {
  local push_origin="$1"
  local tmp
  tmp="$(mktemp -d)"
  git -C "$tmp" init -b main -q
  git -C "$tmp" -c user.name=shipyard -c user.email=shipyard@local \
    commit --allow-empty -q -m "lay the keel: charter $NAME"
  git -C "$tmp" push -q "$DIR/.hold.git" main
  [[ "$push_origin" == "1" ]] && git -C "$DIR/.hold.git" push -q origin main
  rm -rf "$tmp"
}

if [[ -n "$URL" ]]; then
  git clone --bare "$URL" .hold.git
  if ! git -C .hold.git show-ref --verify --quiet refs/heads/main; then
    echo "remote repo has no commits yet -- laying the keel"
    lay_the_keel 1
  fi
else
  git init --bare -b main .hold.git
  lay_the_keel 0
fi

# home-port berth: a plain checkout of main for browsing / manual work
git -C .hold.git worktree add "$DIR/berths/home-port" main >/dev/null

# --- standing orders ---
if [[ ! -f charter.md ]]; then
  cat > charter.md <<EOF
# Charter: $NAME

## Repo
- origin: ${URL:-"(local only)"}
- home port: main · dry dock: integration

## Stack & conventions
- (fill in: languages, frameworks, formatter, lint)

## Test commands
- crew (per-order): (fill in: how crew prove their work -- plain shell, no markdown backticks, e.g. npm test)

Read by \`ship/bin/quartermaster\` before approving a merge into \`integration\` --
keep this field to the exact test invocation, nothing else on the line, and
write it as plain shell (no surrounding backticks) -- this line is run
literally via \`bash -c\`, so a markdown-style \`npm test\` would be captured
with its backticks intact and misread as command substitution.
- dry dock: (fill in -- plain shell, no markdown backticks, e.g. npm test)

## Dev server
Read by \`ship/bin/telescope\` (the deck's "telescope" window) and \`erda telescope\` (the
host-side tunnel). Bind localhost only, never 0.0.0.0 -- access is always via SSH
tunnel, never a raw exposed port. Runs against the integration branch (crew's
merged, reviewed work), not any one crew berth. Same rule as above: plain
shell, no markdown backticks around the value.
- command: (fill in, e.g. npm run dev)
- port: (fill in, e.g. 5173)

## No-touch paths
- (paths crew may never modify, e.g. deploy configs, secrets)

## Notes for the Captain
- (standing context worth having in every mission)
EOF
fi

# --- ship's bus ---
[[ -f .ship/roster.json ]] || echo "[]" > .ship/roster.json
touch .ship/log/events.log .ship/log/ledger.tsv
# Every role defaults to deepinfra -- a charter that never touches the
# backend-switching feature (ship/bin/backend) behaves exactly as before it
# existed; backend-lib.sh's own lookup also defaults any missing file/role
# key to "deepinfra", so this init is a convenience, not load-bearing.
[[ -f .ship/backend.json ]] || printf '{"captain":"deepinfra","crew":"deepinfra","first-mate":"deepinfra","quartermaster":"deepinfra"}\n' > .ship/backend.json
[[ -f .ship/mission.md ]] || printf '# Mission\n\n(no active voyage)\n' > .ship/mission.md

echo "chartered: $NAME"
echo "  hold:    $DIR/.hold.git"
echo "  berths:  $DIR/berths/ (home-port checked out)"
echo "  bus:     $DIR/.ship/"
echo "next: edit $DIR/charter.md, then 'sail $NAME'"
