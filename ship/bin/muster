#!/usr/bin/env bash
# muster — spawn a crew member for one work order
# usage: muster [--redo] [--feedback <file>] <charter> <task-id> <order-file>
#   muster royal-guest T-014 ~/fleet/royal-guest/.ship/orders/T-014-booking-dates.md
# Creates: berth (worktree) + branch crew/<task-id>-<slug> + tmux window running
# the agent headless on the order. Registers in roster.json and the event log.
#
# --redo: crew.md's prescribed reject-and-redo loop ("respawn a FRESH crew
# agent, same order, feedback appended") used to mean the caller manually ran
# `git worktree remove --force` + `git branch -D` before re-mustering the
# same task ID, since a plain muster refuses an occupied berth or an
# existing branch outright. --redo does that cleanup itself.
# --feedback <file>: appends the file's content as a "## Feedback (redo)"
# section on the permanent order (not just the berth's copy), so a later
# redo or manual inspection sees the accumulated history. With --redo and no
# explicit --feedback, defaults to `.ship/reviews/<task-id>.review.md` if one
# exists -- the exact file the Quartermaster's own REJECT already wrote.
set -euo pipefail

REDO=0
FEEDBACK_FILE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --redo) REDO=1; shift ;;
    --feedback) FEEDBACK_FILE="${2:?--feedback requires a file path}"; shift 2 ;;
    --) shift; break ;;
    -*) echo "unknown flag: $1" >&2; exit 1 ;;
    *) break ;;
  esac
done

# resolve the real shipyard checkout even when invoked via the
# /usr/local/bin symlink fitout.sh sets up (readlink -f, not just
# dirname "${BASH_SOURCE[0]}", which would resolve to the symlink itself)
SHIPYARD_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../.." && pwd)"

FLEET="${FLEET:-$HOME/fleet}"
# Crew default per the plan's model routing policy: GLM-5.2 High via the
# Trade Winds (DeepInfra) -- see ship/pi/models.json. --append-system-prompt
# wires in the crew role contract (commit, write a report, SOS conditions) --
# without it pi only ever sees the order text, not what it's supposed to do
# with it. Override for tests or the relief vessel: SHIP_AGENT="opencode run",
# or escalate a stuck task with SHIP_AGENT="pi -p --provider deepinfra --model
# zai-org/GLM-5.2 --thinking xhigh --append-system-prompt $SHIPYARD_DIR/ship/prompts/crew.md"
#
# The model itself is resolved by `pick-model` at the crew window's actual
# run time (inside .crew-run.sh below, once unlock has loaded
# DEEPINFRA_API_KEY), not hardcoded here -- health-checks
# ship/models-priority.txt against a real DeepInfra call and falls through
# to the next entry if the top-priority model isn't responding. The `\$`
# escaping is deliberate: this text is embedded literally into the generated
# .crew-run.sh heredoc below and must stay unexpanded until that script
# actually runs. Skipped entirely if SHIP_AGENT is set -- an explicit
# override means "run exactly this," including forgoing --mode json/pi-monitor
# below (a stub agent's own plain-text output wouldn't be valid NDJSON, so
# piping it through a JSON formatter would just silently swallow it).
if [[ -n "${SHIP_AGENT:-}" ]]; then
  AGENT_CMD="$SHIP_AGENT"
  MONITOR_PIPE=""
else
  AGENT_CMD="MODEL=\$(pick-model 2>&2 || echo zai-org/GLM-5.2); pi --mode json --provider deepinfra --model \"\$MODEL\" --thinking high --append-system-prompt $SHIPYARD_DIR/ship/prompts/crew.md"
  # --mode json (instead of -p) + pi-monitor is what actually makes a crew
  # window show anything while the agent works -- -p prints nothing until
  # the whole task is done, so the window used to sit blank for the entire
  # run. Reasoning/tool-call content is already generated (and paid for)
  # either way; this only changes what gets displayed, not what's requested
  # from the model, so it's free. MONITOR_PIPE's value is spliced into the
  # .crew-run.sh heredoc below the same way AGENT_CMD is -- literal text in
  # the generated script, not a runtime variable, so the `|` really does
  # become a pipe when that script runs.
  MONITOR_PIPE=" | pi-monitor"
fi

USAGE="usage: muster [--redo] [--feedback <file>] <charter> <task-id> <order-file>"
NAME="${1:?$USAGE}"
TASK="${2:?$USAGE}"
ORDER="${3:?$USAGE}"

DIR="$FLEET/$NAME"
SES="ship-$NAME"
HOLD="$DIR/.hold.git"
BERTH="$DIR/berths/$TASK"
BUS="$DIR/.ship"

[[ "$NAME" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]] || {
  echo "invalid charter name: '$NAME' (letters, digits, - and _ only)" >&2
  exit 1
}
[[ "$TASK" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]] || {
  echo "invalid task id: '$TASK' (letters, digits, - and _ only)" >&2
  exit 1
}
[[ -d "$HOLD" ]] || { echo "no hold for charter '$NAME' — run: charter $NAME" >&2; exit 1; }
[[ -f "$ORDER" ]] || { echo "order file not found: $ORDER" >&2; exit 1; }
tmux has-session -t "=$SES" 2>/dev/null || { echo "deck not open — run: sail $NAME" >&2; exit 1; }

# slug from order filename: T-014-booking-dates.md -> booking-dates
BASE="$(basename "$ORDER" .md)"
SLUG="${BASE#"$TASK"-}"; [[ "$SLUG" == "$BASE" ]] && SLUG="task"
BRANCH="crew/$TASK-$SLUG"

# A plain muster refuses an occupied berth or an existing branch outright --
# --redo clears both instead, the cleanup crew.md's documented reject-and-
# redo loop always needed but never actually got (found live: this was
# manual `git worktree remove --force` + `git branch -D` every time before
# this flag existed).
if [[ -e "$BERTH" ]]; then
  if [[ "$REDO" -eq 1 ]]; then
    echo "muster --redo: removing existing berth $BERTH" >&2
    git -C "$HOLD" worktree remove --force "$BERTH" 2>/dev/null || rm -rf "$BERTH"
  else
    echo "berth already occupied: $BERTH (use --redo to replace it)" >&2
    exit 1
  fi
fi
if git -C "$HOLD" show-ref --verify --quiet "refs/heads/$BRANCH"; then
  if [[ "$REDO" -eq 1 ]]; then
    echo "muster --redo: dropping existing branch $BRANCH" >&2
    git -C "$HOLD" branch -D "$BRANCH" >/dev/null
  else
    echo "branch already exists: $BRANCH (use --redo to replace it)" >&2
    exit 1
  fi
fi

# --redo with no explicit --feedback: default to the Quartermaster's own
# REJECT review, if one exists for this exact task -- the real, common case
# (redo right after a reject) needs nothing extra typed.
if [[ "$REDO" -eq 1 && -z "$FEEDBACK_FILE" && -f "$BUS/reviews/$TASK.review.md" ]]; then
  FEEDBACK_FILE="$BUS/reviews/$TASK.review.md"
fi
if [[ -n "$FEEDBACK_FILE" ]]; then
  [[ -f "$FEEDBACK_FILE" ]] || { echo "feedback file not found: $FEEDBACK_FILE" >&2; exit 1; }
  printf '\n## Feedback (redo)\n%s\n' "$(cat "$FEEDBACK_FILE")" >> "$ORDER"
fi

# --- crew name: a human-readable callsign, not just a task ID ---
# Invented, hobbit-flavored names -- deliberately NOT any name from Tolkien's
# own hobbit genealogies (which run surprisingly deep, including flower names
# for Sam Gamgee's children -- Rose/Daisy/Marigold/Ruby/Primrose/Pearl/Pansy/
# Goldilocks/Elanor are all real hobbit names and excluded on purpose). Only
# avoids collision with currently-*active* crew in this charter, not every
# name ever used -- identity within one glance at the roster is the goal,
# not permanent uniqueness across a charter's whole history.
CREW_NAMES=(Alder Barley Birch Bracken Bramble Bumble Buttercup Clover Cricket
  Dandelion Fennel Fern Foxglove Hazel Juniper Linden Marrow Meadow Nettle
  Oaken Pebble Poppy Rowan Sage Sorrel Sparrow Tansy Thistle Willow Wren Yarrow)
ACTIVE_NAMES="$(jq -r '.[] | select(.status=="working") | .name // empty' "$BUS/roster.json" 2>/dev/null)"
CREWNAME=""
while IFS= read -r candidate; do
  if ! grep -qxF "$candidate" <<< "$ACTIVE_NAMES"; then
    CREWNAME="$candidate"
    break
  fi
done < <(printf '%s\n' "${CREW_NAMES[@]}" | shuf)
# pool exhausted (every name currently in use) -- vanishingly unlikely given
# typical crew sizes, but degrade gracefully rather than fail muster outright
[[ -z "$CREWNAME" ]] && CREWNAME="${CREW_NAMES[$((RANDOM % ${#CREW_NAMES[@]}))]}-$TASK"

log() { printf '%s\t%s\t%s\n' "$(date -Is)" "$1" "$2" >> "$BUS/log/events.log"; }

# --- berth + branch ---
# Cut from `integration`, not `main` -- `main` only advances at the final
# INTEGRATE step, so on any multi-wave voyage every berth after wave 1 used
# to start without wave 1's own merged work (no package.json, no src/, stale
# by however much has already landed on `integration`). `integration` is the
# already-reviewed *build* boundary; `main` is the *publish* boundary --
# conflating them cost real crew turns on a real voyage (found via the
# Captain's own voyage-debrief.md, confirmed against this exact line before
# fixing it). Same existence check ship/bin/quartermaster and
# ship/bin/telescope already use for the same reason: `integration` doesn't
# exist until the first `/review` creates it, so fall back to `main` until
# then.
BASE_REF="main"
git -C "$HOLD" show-ref --verify --quiet refs/heads/integration && BASE_REF="integration"
git -C "$HOLD" worktree add "$BERTH" -b "$BRANCH" "$BASE_REF" >/dev/null

# A fresh worktree has no node_modules even when the project needs one --
# every crew discovered this independently on the same real voyage and
# improvised differently (symlink, hardlink-copy, npm install), burning
# turns each time. Hardlink-copy (not a live symlink) from the integration
# worktree's own node_modules if it has one: cheap (shared inodes, no real
# duplication) but still gives each berth an independent directory tree, so
# one crew's own `npm install` can't mutate a sibling's concurrently-running
# berth the way a shared symlink would. No-op for non-Node charters or
# before `integration` has any installed deps yet.
if [[ -d "$DIR/berths/integration/node_modules" ]]; then
  cp -al "$DIR/berths/integration/node_modules" "$BERTH/node_modules" 2>/dev/null || true
fi

cp "$ORDER" "$BERTH/.order.md"
# crew.md says "write .ship/reports/<TASK-ID>.report.md" without saying
# relative to what -- the agent's cwd is the berth, and a real run wrote a
# stray .ship/ *inside* the berth instead of the charter's actual bus.
# Make the path unambiguous per-order instead of trusting relative-path
# inference (which also breaks if the berths/charter nesting ever changes).
printf '\n## Report path\nWrite your report to exactly this absolute path: %s/reports/%s.report.md\n' \
  "$BUS" "$TASK" >> "$BERTH/.order.md"
[[ -f "$DIR/charter.md" ]] && cp "$DIR/charter.md" "$BERTH/.charter.md"
# berth scaffolding must never be committed, even via `git add -A`.
# info/exclude is shared across all worktrees of the hold, so guard against
# appending these lines again on every muster.
EXCL="$(git -C "$BERTH" rev-parse --git-path info/exclude)"
grep -qxF '.crew-run.sh' "$EXCL" 2>/dev/null || printf '.order.md\n.charter.md\n.crew-run.sh\n' >> "$EXCL"

# Real tmux window name -- computed here (not down by the tmux new-window
# call below) so roster.json's own "window" field can store it exactly.
# Found and fixed a real bug while wiring this: roster.json used to store
# the bare $CREWNAME here, but the actual tmux window carries a glyph prefix
# by default (SHIP_GLYPHS=1) -- confirmed live that `tmux select-window`
# does NOT substring-match a bare name against a glyph-prefixed one, so
# Chartroom's "jump to crew window" (scuttlebutt/plugins/chartroom.ts,
# targeting `ship-<charter>:<roster window field>`) was silently broken for
# any charter running with the default glyph setting. Storing the exact,
# already-glyph-decorated name here fixes it for both settings.
WIN="$CREWNAME"; [[ "${SHIP_GLYPHS:-1}" == "1" ]] && WIN="👷 $WIN"

# --- roster entry ---
# Drop any existing entry for this task before appending the new one -- a
# rejected attempt re-mustered against the same task ID (crew.md's prescribed
# "fresh agent, same order" redo loop) would otherwise leave the old, now-
# meaningless entry sitting in the roster forever. Worse: the completion-time
# status update below matches by task ID alone, so with two entries sharing
# one task ID it would silently mark BOTH done/failed regardless of which one
# actually ran -- found by actually exercising the redo loop for real, not by
# reading the script.
(
  flock 9
  TMPJ="$(mktemp)"
  jq --arg t "$TASK" --arg b "$BRANCH" --arg w "$WIN" --arg n "$CREWNAME" --arg s "$(date -Is)" \
     '[.[] | select(.task != $t)] + [{task:$t, name:$n, branch:$b, window:$w, started:$s, status:"working"}]' \
     "$BUS/roster.json" > "$TMPJ" && mv "$TMPJ" "$BUS/roster.json"
) 9>"$BUS/.roster.lock"
log "muster" "$TASK $BRANCH"

# --- crew window: run agent, then report status and hold the pane for inspection ---
RUNNER="$BERTH/.crew-run.sh"
cat > "$RUNNER" <<EOF
#!/usr/bin/env bash
set -uo pipefail
cd "$BERTH" || exit 1
# Context for cost-proxy's ledger attribution (see ship/pi/models.json's
# X-Ship-* headers) -- must be exported before unlock/pi run, not after.
export SHIP_ROLE=crew SHIP_CHARTER="$NAME" SHIP_NAME="$CREWNAME" SHIP_TASK="$TASK"
# load the strongbox if a key is present; unlock itself degrades gracefully
# (prints a stderr note, sets nothing) when the strongbox or key is missing,
# so this is a no-op for stub agents that don't need DEEPINFRA_API_KEY.
command -v unlock >/dev/null 2>&1 && eval "\$(unlock)"
# AGENT_CMD is spliced below as raw shell source (not a quoted string) so
# operators can override SHIP_AGENT with a command that itself needs internal
# quoting (e.g. a multi-statement stub, or a flag value with spaces). That
# means it must never be embedded a second time inside an already-quoted
# string -- an AGENT_CMD containing a literal '"' would prematurely close the
# surrounding quotes, corrupt this line's word boundaries, and silently run
# the wrong commands. printf %q here produces a single shell-safe token that
# reconstructs the exact original string at runtime for display only; the
# real invocation below is unaffected.
printf '[%s/%s] agent: %s · branch: %s\n' "$CREWNAME" "$TASK" $(printf '%q' "$AGENT_CMD") "$BRANCH"
$AGENT_CMD "\$(cat .order.md)"$MONITOR_PIPE
RC=\$?
# shellcheck disable=SC1010  # false positive: "done" here is a literal status value, not the keyword
STATUS=done
[[ \$RC -ne 0 ]] && STATUS=failed
# roster.json used to be unable to distinguish a clean SOS exit from a
# normal success -- both wrote "done", so the Captain had to read every
# report in full to catch one. crew.md's prime directive now has crew make
# the report's first line exactly "Status: SOS" when raising SOS; surface
# that here as its own roster status. Only checked on an otherwise-clean
# exit -- a nonzero RC is a crash, not a considered SOS, and stays "failed".
if [[ "\$STATUS" == done ]] && [[ -f "$BUS/reports/$TASK.report.md" ]] && \
   head -n1 "$BUS/reports/$TASK.report.md" | grep -qEi '^Status:[[:space:]]*SOS[[:space:]]*\$'; then
  STATUS=sos
fi
(
  flock 9
  TMPJ="\$(mktemp)"
  jq --arg t "$TASK" --arg s "\$STATUS" \
     '(.[] | select(.task==\$t) | .status) = \$s' \
     "$BUS/roster.json" > "\$TMPJ" && mv "\$TMPJ" "$BUS/roster.json"
) 9>"$BUS/.roster.lock"
printf '%s\t%s\t%s\n' "\$(date -Is)" "crew-\$STATUS" "$TASK rc=\$RC" >> "$BUS/log/events.log"
echo; echo "[$CREWNAME/$TASK] \$STATUS (rc=\$RC) — report expected in .ship/reports/$TASK.report.md"
# Window closes on its own from here (no read -r/keypress wait) -- tmux's
# default (remain-on-exit off, confirmed not set anywhere in
# dotfiles/tmux/ship.tmux.conf) closes a window the instant its pane's
# command exits. The bridge no longer needs a human to babysit finished crew
# windows to notice completion anyway -- the wave-completion watcher (§4bi)
# already wakes the Captain with the real report content the moment a wave
# finishes, and roster.json/events.log/the report file are the durable
# record; the tmux pane itself was never the source of truth.
EOF
chmod +x "$RUNNER"

tmux new-window -t "$SES" -n "$WIN" "$RUNNER"
echo "mustered $TASK as '$CREWNAME' on $BRANCH → window $WIN (deck: $SES)"
