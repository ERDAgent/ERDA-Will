#!/usr/bin/env bash
# muster — spawn a crew member for one work order
# usage: muster [--redo] [--feedback <file>] <charter> <task-id> <order-file>
#   muster royal-guest T-014 ~/fleet/royal-guest/.ship/orders/T-014-booking-dates.md
# Creates: berth (worktree) + branch crew/<task-id>-<slug> + tmux window running
# the agent headless on the order. Registers in roster.json and the event log.
#
# --redo: crew.md's prescribed reject-and-redo loop ("respawn a FRESH crew
# agent, same order, feedback appended") used to mean the caller manually ran
# `git worktree remove --force` + `git branch -D` before re-mustering the
# same task ID, since a plain muster refuses an occupied berth or an
# existing branch outright. --redo does that cleanup itself.
# --feedback <file>: appends the file's content as a "## Feedback (redo)"
# section on the permanent order (not just the berth's copy), so a later
# redo or manual inspection sees the accumulated history. With --redo and no
# explicit --feedback, defaults to `.ship/reviews/<task-id>.review.md` if one
# exists -- the exact file the Quartermaster's own REJECT already wrote.
#
# Backend-aware (see ship/backends.json + .ship/backend.json): the crew
# agent's command is resolved from whichever backend is active for the
# `crew` role on this charter (default: deepinfra/pi, unchanged from before
# this feature existed). SHIP_AGENT still overrides everything -- an
# explicit override means "run exactly this," same as always.
set -euo pipefail

REDO=0
FEEDBACK_FILE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --redo) REDO=1; shift ;;
    --feedback) FEEDBACK_FILE="${2:?--feedback requires a file path}"; shift 2 ;;
    --) shift; break ;;
    -*) echo "unknown flag: $1" >&2; exit 1 ;;
    *) break ;;
  esac
done

# resolve the real shipyard checkout even when invoked via the
# /usr/local/bin symlink fitout.sh sets up (readlink -f, not just
# dirname "${BASH_SOURCE[0]}", which would resolve to the symlink itself)
SHIPYARD_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../.." && pwd)"
# shellcheck source=ship/bin/backend-lib.sh
source "$SHIPYARD_DIR/ship/bin/backend-lib.sh"

FLEET="${FLEET:-$HOME/fleet}"

USAGE="usage: muster [--redo] [--feedback <file>] <charter> <task-id> <order-file>"
NAME="${1:?$USAGE}"
TASK="${2:?$USAGE}"
ORDER="${3:?$USAGE}"

DIR="$FLEET/$NAME"
SES="ship-$NAME"
BUS="$DIR/.ship"

[[ "$NAME" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]] || {
  echo "invalid charter name: '$NAME' (letters, digits, - and _ only)" >&2
  exit 1
}
tmux has-session -t "=$SES" 2>/dev/null || { echo "deck not open — run: sail $NAME" >&2; exit 1; }

# --- berth: worktree + branch (shared primitive, also used by delegate-claude/delegate-codex) ---
BERTH_ARGS=("$NAME" "$TASK" "$ORDER")
[[ "$REDO" -eq 1 ]] && BERTH_ARGS+=(--redo)
[[ -n "$FEEDBACK_FILE" ]] && BERTH_ARGS+=(--feedback "$FEEDBACK_FILE")
eval "$("$SHIPYARD_DIR/ship/bin/berth" create "${BERTH_ARGS[@]}")"
# BERTH, BRANCH now set by berth's own `eval "$(...)"` output contract.

# Crew default per the plan's model routing policy: GLM-5.2 High via the
# default Trade Wind, DeepInfra/GLM-5.2 -- see ship/pi/models.json. Resolved from
# ship/backends.json + .ship/backend.json's `crew` entry unless SHIP_AGENT
# overrides everything (an explicit override means "run exactly this,"
# including forgoing --mode json/pi-monitor below -- a stub agent's own
# plain-text output wouldn't be valid NDJSON, so piping it through a JSON
# formatter would just silently swallow it).
CREW_PROMPT="$SHIPYARD_DIR/ship/prompts/crew.md"
# RATE_PATTERNS_JOINED/AUTO_SWITCH_TO drive the reactive auto-switch below --
# empty for the override case and for deepinfra (DeepInfra-level fallback is
# already pick-model's job, not this feature's) so detection is a no-op
# there, same as before this feature existed.
RATE_PATTERNS_JOINED=""
AUTO_SWITCH_TO=""
if [[ -n "${SHIP_AGENT:-}" ]]; then
  AGENT_CMD="$SHIP_AGENT"
  AGENT_SETUP=""
  MONITOR_PIPE=""
  # bound (even if unused -- RATE_PATTERNS_JOINED stays empty for an
  # override, so the detection block below never really needs this) so the
  # heredoc's own generation-time $BACKEND reference doesn't trip this
  # script's own `set -u`.
  BACKEND="override"
  # unconditional regardless of override, matching pre-registry behavior --
  # a stub/test agent may not need DEEPINFRA_API_KEY, but loading crew scope
  # is a harmless no-op when it's not needed and required when it is.
  # shellcheck disable=SC2016  # single-quoted on purpose: stays literal until spliced into .crew-run.sh and run there
  AUTH_SETUP='command -v unlock >/dev/null 2>&1 && eval "$(unlock)"'
  PROMPT_MODE="flag"
else
  BACKEND="$(backend_get "$DIR" crew)"
  AGENT_SETUP="$(backend_field "$BACKEND" '.launch.crew.setup')"
  AGENT_CMD="$(backend_render "$(backend_field "$BACKEND" '.launch.crew.cmd')" "PROMPT_FILE=$CREW_PROMPT" "BUS_DIR=$BUS")"
  MONITOR_PIPE="$(backend_field "$BACKEND" '.launch.crew.monitor_pipe // ""')"
  AUTH_SETUP="$(backend_auth_setup "$BACKEND" crew)"
  PROMPT_MODE="$(backend_field "$BACKEND" '.prompt_mode')"
  RATE_PATTERNS_JOINED="$(backend_field "$BACKEND" '.rate_limit_patterns | join("|")')"
  AUTO_SWITCH_TO="$(backend_field "$BACKEND" '.auto_switch_to // ""')"
fi
AGENT_LOG="$BERTH/.agent-output.log"
# SHIP_AGENT means "run exactly this" -- no wrapping, tee included, so an
# override's stdout/stderr behavior stays pristine. Otherwise: a monitor
# pipe (pi-monitor's NDJSON parser) must receive pi's stdout untouched --
# interleaving stderr via 2>&1 upstream of it could corrupt the NDJSON
# stream -- so the tee-for-detection wrapping only applies when there's no
# monitor pipe (claude/codex today). deepinfra's RATE_PATTERNS_JOINED is
# empty anyway, so this never loses real detection coverage.
if [[ -n "${SHIP_AGENT:-}" ]]; then
  INVOKE_LINE="$AGENT_CMD \"\$(cat .order.md)\""
elif [[ -n "$MONITOR_PIPE" ]]; then
  INVOKE_LINE="$AGENT_CMD \"\$(cat .order.md)\"$MONITOR_PIPE"
else
  INVOKE_LINE="$AGENT_CMD \"\$(cat .order.md)\" 2>&1 | tee \"$AGENT_LOG\""
fi

# Codex has no --append-system-prompt equivalent -- crew.md's contract goes
# in via AGENTS.md in the berth's own cwd instead (see
# docs/backend-verification-notes.md). Harmless/unused for any other
# backend's prompt_mode ("flag").
if [[ "$PROMPT_MODE" == "agents_md" ]]; then
  cp "$CREW_PROMPT" "$BERTH/AGENTS.md"
fi

# --- crew name: a human-readable callsign, not just a task ID ---
# Invented, hobbit-flavored names -- deliberately NOT any name from Tolkien's
# own hobbit genealogies (which run surprisingly deep, including flower names
# for Sam Gamgee's children -- Rose/Daisy/Marigold/Ruby/Primrose/Pearl/Pansy/
# Goldilocks/Elanor are all real hobbit names and excluded on purpose). Only
# avoids collision with currently-*active* crew in this charter, not every
# name ever used -- identity within one glance at the roster is the goal,
# not permanent uniqueness across a charter's whole history.
CREW_NAMES=(Alder Barley Birch Bracken Bramble Bumble Buttercup Clover Cricket
  Dandelion Fennel Fern Foxglove Hazel Juniper Linden Marrow Meadow Nettle
  Oaken Pebble Poppy Rowan Sage Sorrel Sparrow Tansy Thistle Willow Wren Yarrow)
ACTIVE_NAMES="$(jq -r '.[] | select(.status=="working") | .name // empty' "$BUS/roster.json" 2>/dev/null)"
CREWNAME=""
while IFS= read -r candidate; do
  if ! grep -qxF "$candidate" <<< "$ACTIVE_NAMES"; then
    CREWNAME="$candidate"
    break
  fi
done < <(printf '%s\n' "${CREW_NAMES[@]}" | shuf)
# pool exhausted (every name currently in use) -- vanishingly unlikely given
# typical crew sizes, but degrade gracefully rather than fail muster outright
[[ -z "$CREWNAME" ]] && CREWNAME="${CREW_NAMES[$((RANDOM % ${#CREW_NAMES[@]}))]}-$TASK"

log() { printf '%s\t%s\t%s\n' "$(date -Is)" "$1" "$2" >> "$BUS/log/events.log"; }

# Real tmux window name -- computed here (not down by the tmux new-window
# call below) so roster.json's own "window" field can store it exactly.
# Found and fixed a real bug while wiring this: roster.json used to store
# the bare $CREWNAME here, but the actual tmux window carries a glyph prefix
# by default (SHIP_GLYPHS=1) -- confirmed live that `tmux select-window`
# does NOT substring-match a bare name against a glyph-prefixed one, so
# Chartroom's "jump to crew window" (scuttlebutt/plugins/chartroom.ts,
# targeting `ship-<charter>:<roster window field>`) was silently broken for
# any charter running with the default glyph setting. Storing the exact,
# already-glyph-decorated name here fixes it for both settings.
WIN="$CREWNAME"; [[ "${SHIP_GLYPHS:-1}" == "1" ]] && WIN="👷 $WIN"

"$SHIPYARD_DIR/ship/bin/roster-note" register "$NAME" "$TASK" --name "$CREWNAME" --branch "$BRANCH" --window "$WIN"
log "muster" "$TASK $BRANCH"

# --- crew window: run agent, then report status and hold the pane for inspection ---
RUNNER="$BERTH/.crew-run.sh"
cat > "$RUNNER" <<EOF
#!/usr/bin/env bash
set -uo pipefail
cd "$BERTH" || exit 1
# Context for cost-proxy's ledger attribution (see ship/pi/models.json's
# X-Ship-* headers) -- must be exported before unlock/pi run, not after.
export SHIP_ROLE=crew SHIP_CHARTER="$NAME" SHIP_NAME="$CREWNAME" SHIP_TASK="$TASK"
# load whatever this backend's auth needs; degrades gracefully (prints a
# stderr note, sets nothing) when the strongbox/key/login is missing, so
# this is a no-op for stub agents that don't need real credentials.
$AUTH_SETUP
$AGENT_SETUP
# AGENT_CMD is spliced below as raw shell source (not a quoted string) so
# operators can override SHIP_AGENT with a command that itself needs internal
# quoting (e.g. a multi-statement stub, or a flag value with spaces). That
# means it must never be embedded a second time inside an already-quoted
# string -- an AGENT_CMD containing a literal '"' would prematurely close the
# surrounding quotes, corrupt this line's word boundaries, and silently run
# the wrong commands. printf %q here produces a single shell-safe token that
# reconstructs the exact original string at runtime for display only; the
# real invocation below is unaffected.
printf '[%s/%s] agent: %s · branch: %s\n' "$CREWNAME" "$TASK" $(printf '%q' "$AGENT_CMD") "$BRANCH"
$INVOKE_LINE
RC=\$?
# shellcheck disable=SC1010  # false positive: "done" here is a literal status value, not the keyword
STATUS=done
[[ \$RC -ne 0 ]] && STATUS=failed
# roster.json used to be unable to distinguish a clean SOS exit from a
# normal success -- both wrote "done", so the Captain had to read every
# report in full to catch one. crew.md's prime directive now has crew make
# the report's first line exactly "Status: SOS" when raising SOS; surface
# that here as its own roster status. Only checked on an otherwise-clean
# exit -- a nonzero RC is a crash, not a considered SOS, and stays "failed".
if [[ "\$STATUS" == done ]] && [[ -f "$BUS/reports/$TASK.report.md" ]] && \
   head -n1 "$BUS/reports/$TASK.report.md" | grep -qEi '^Status:[[:space:]]*SOS[[:space:]]*\$'; then
  STATUS=sos
fi
# Reactive auto-switch: only reachable when this backend has real patterns
# configured (empty for deepinfra/override -- see muster's own comment on
# RATE_PATTERNS_JOINED). Next-spawn-only by design: this flips
# .ship/backend.json's \`crew\` entry for the *next* muster/delegate call --
# it never touches the task that just ran.
if [[ -n "$RATE_PATTERNS_JOINED" ]] && [[ -f "$AGENT_LOG" ]] && grep -qiE "$RATE_PATTERNS_JOINED" "$AGENT_LOG"; then
  printf '%s\t%s\t%s\n' "\$(date -Is)" "rate-limit-detected" "$TASK backend=$BACKEND" >> "$BUS/log/events.log"
  if [[ -n "$AUTO_SWITCH_TO" ]]; then
    "$SHIPYARD_DIR/ship/bin/backend" "$NAME" crew "$AUTO_SWITCH_TO" >/dev/null
  fi
fi
"$SHIPYARD_DIR/ship/bin/roster-note" status "$NAME" "$TASK" "\$STATUS"
printf '%s\t%s\t%s\n' "\$(date -Is)" "crew-\$STATUS" "$TASK rc=\$RC" >> "$BUS/log/events.log"
echo; echo "[$CREWNAME/$TASK] \$STATUS (rc=\$RC) — report expected in .ship/reports/$TASK.report.md"
# Window closes on its own from here (no read -r/keypress wait) -- tmux's
# default (remain-on-exit off, confirmed not set anywhere in
# dotfiles/tmux/ship.tmux.conf) closes a window the instant its pane's
# command exits. The bridge no longer needs a human to babysit finished crew
# windows to notice completion anyway -- the wave-completion watcher (§4bi)
# already wakes the Captain with the real report content the moment a wave
# finishes, and roster.json/events.log/the report file are the durable
# record; the tmux pane itself was never the source of truth.
EOF
chmod +x "$RUNNER"

tmux new-window -t "$SES" -n "$WIN" "$RUNNER"
echo "mustered $TASK as '$CREWNAME' on $BRANCH → window $WIN (deck: $SES)"
