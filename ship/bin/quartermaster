#!/usr/bin/env bash
# quartermaster — review & merge gate for one crew work order (Phase 5)
# usage: quartermaster <charter> <task-id>
#   quartermaster royal-guest T-014
#
# Merges the crew's branch into `integration` (dry dock), runs the charter's
# dry-dock test command for real, then hands a headless, tool-less review
# agent the order + report + diff + real test result to judge APPROVE/REJECT
# against the order's acceptance criteria. The script does every mechanical
# thing itself (merge, test execution, rollback on rejection) — the LLM only
# ever emits a verdict + feedback, the same split /mission and /debrief
# already use (deterministic gathering, LLM judgment). See
# ship/prompts/quartermaster.md for the reviewer's contract.
#
# Deterministic outcomes never need the LLM at all: a merge conflict or a
# failing dry-dock test is an automatic REJECT (this mirrors captain.md's own
# hard rule -- "never merge to main without dry-dock tests passing" -- now
# enforced here instead of trusted to the Captain's own judgment call).
set -euo pipefail

SHIPYARD_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../.." && pwd)"
# shellcheck source=ship/bin/backend-lib.sh
source "$SHIPYARD_DIR/ship/bin/backend-lib.sh"
FLEET="${FLEET:-$HOME/fleet}"

NAME="${1:?usage: quartermaster <charter> <task-id>}"
TASK="${2:?usage: quartermaster <charter> <task-id>}"

[[ "$NAME" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]] || {
  echo "invalid charter name: '$NAME' (letters, digits, - and _ only)" >&2
  exit 1
}
[[ "$TASK" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]] || {
  echo "invalid task id: '$TASK' (letters, digits, - and _ only)" >&2
  exit 1
}

DIR="$FLEET/$NAME"
HOLD="$DIR/.hold.git"
BUS="$DIR/.ship"
INTWT="$DIR/berths/integration"
CHARTER_MD="$DIR/charter.md"

[[ -d "$HOLD" ]] || { echo "no hold for charter '$NAME' — run: charter $NAME" >&2; exit 1; }

ROSTER="$BUS/roster.json"
ENTRY="$(jq -c --arg t "$TASK" '[.[] | select(.task==$t)][0] // empty' "$ROSTER" 2>/dev/null || true)"
[[ -n "$ENTRY" ]] || { echo "no roster entry for task '$TASK' — has it been mustered?" >&2; exit 1; }

STATUS="$(jq -r '.status' <<< "$ENTRY")"
BRANCH="$(jq -r '.branch' <<< "$ENTRY")"

case "$STATUS" in
  working)
    echo "quartermaster: '$TASK' is still working — nothing to review yet" >&2
    exit 1
    ;;
  merged)
    echo "quartermaster: '$TASK' was already merged into integration — nothing to do" >&2
    exit 0
    ;;
  sos)
    echo "quartermaster: '$TASK' raised SOS — this needs your own judgment (crew.md's prime" >&2
    echo "directive), not a merge-gate review. Read $BUS/reports/$TASK.report.md, then either" >&2
    echo "fix the order/scope and 'muster --redo $TASK', or resolve it another way." >&2
    exit 1
    ;;
esac

REPORT="$BUS/reports/$TASK.report.md"
[[ -f "$REPORT" ]] || { echo "no report yet at $REPORT — crew hasn't finished" >&2; exit 1; }

mapfile -t ORDER_MATCHES < <(compgen -G "$BUS/orders/$TASK-*.md" || true)
[[ "${#ORDER_MATCHES[@]}" -eq 1 ]] || {
  echo "expected exactly one order file matching $BUS/orders/$TASK-*.md, found ${#ORDER_MATCHES[@]}" >&2
  exit 1
}
ORDER="${ORDER_MATCHES[0]}"

git -C "$HOLD" show-ref --verify --quiet "refs/heads/$BRANCH" || {
  echo "no such branch in the hold: $BRANCH" >&2
  exit 1
}

mkdir -p "$BUS/reviews"
REVIEW="$BUS/reviews/$TASK.review.md"
log() { printf '%s\t%s\t%s\n' "$(date -Is)" "$1" "$2" >> "$BUS/log/events.log"; }

# set_status/set_salvage extracted into ship/bin/roster-note (shared with
# muster's own roster-append and any delegate-claude/delegate-codex capsule)
# -- same flock+jq+mktemp+mv idiom either way, one copy instead of three.
set_status() { "$SHIPYARD_DIR/ship/bin/roster-note" status "$NAME" "$TASK" "$1"; }
set_salvage() { "$SHIPYARD_DIR/ship/bin/roster-note" salvage "$NAME" "$TASK" "$1"; }

# The diff that actually matters is what the crew introduced since they
# forked -- but "forked from main" was a false assumption: `berth` (which
# actually creates crew branches) cuts from `integration` once it exists,
# not `main` -- see its own "Cut from integration, not main" comment, which
# already says "same existence check quartermaster/telescope already use"
# on the assumption this script did this. It didn't: every task reviewed
# after the mission's first therefore diffed against `main`, dragging in
# every already-merged sibling task's changes as if they were new in this
# task, polluting the reviewer's diff (and, worse, its verdict) with old,
# already-approved code it had no reason to re-litigate. Same existence
# check as `berth`/`telescope`, so the diff's base always matches the
# branch's real fork point regardless of how far integration has advanced
# since (three-dot diff's merge-base still finds it either way). Computed
# up front, directly on the bare hold, independent of the merge attempt
# below.
BASE_REF="main"
git -C "$HOLD" show-ref --verify --quiet refs/heads/integration && BASE_REF="integration"

# Real voyage (T-001): a regenerated package-lock.json dominated the diff,
# and the old single 300 KB cap-from-byte-zero spent its whole budget on
# the lockfile, leaving zero bytes for the actual application/test/UI
# changes -- Quartermaster REJECTed for "missing evidence" it was never
# shown. Fix: always include the whole-changeset `git diff --stat` (small,
# never truncated, so the reviewer sees every touched file at a glance);
# for known lockfiles, show only the filename + new blob hash instead of
# content (a reviewer doesn't need lockfile bytes to judge acceptance
# criteria, just confirmation it changed); truncate every other file's
# diff *individually* against its own cap, plus a combined ceiling as a
# last-resort safety net, so one huge non-lockfile can't crowd out the
# rest either.
LOCKFILE_RE='(^|/)(package-lock\.json|npm-shrinkwrap\.json|yarn\.lock|pnpm-lock\.yaml|composer\.lock|Gemfile\.lock|Cargo\.lock|poetry\.lock|Pipfile\.lock|go\.sum|mix\.lock|flake\.lock|packages\.lock\.json|Podfile\.lock|[^/]*-lock\.json)$'
PER_FILE_DIFF_CAP=60000
TOTAL_DIFF_CAP=300000

DIFF_TMP="$(mktemp)"
# Single EXIT trap for every temp resource this script creates (CTXFILE/
# REVIEW_LOG/QM_PROMPT_DIR are assigned later, below) -- trap replaces
# rather than accumulates, so setting it again down there would silently
# drop this cleanup on every exit path (including reject()/approve()'s
# own `exit 0`).
CTXFILE=""
REVIEW_LOG=""
QM_PROMPT_DIR=""
trap 'rm -f "$DIFF_TMP" "${CTXFILE:-}" "${REVIEW_LOG:-}"; [[ -n "${QM_PROMPT_DIR:-}" ]] && rm -rf "$QM_PROMPT_DIR"' EXIT

{
  echo "## Overall stat (git diff --stat -- every touched file, never truncated)"
  git -C "$HOLD" diff --stat "$BASE_REF...$BRANCH" 2>/dev/null || true
  echo

  # -z/-d '' round-trip: filenames survive spaces/unicode without git's
  # quoting getting in the way of the later `-- "$f"` lookups below.
  mapfile -d '' -t CHANGED_FILES < <(git -C "$HOLD" diff --name-only -z "$BASE_REF...$BRANCH" 2>/dev/null || true)
  total=0
  for f in "${CHANGED_FILES[@]}"; do
    [[ -n "$f" ]] || continue
    if [[ "$f" =~ $LOCKFILE_RE ]]; then
      newblob="$(git -C "$HOLD" rev-parse "$BRANCH:$f" 2>/dev/null || echo "(deleted)")"
      echo "## $f"
      echo "(lockfile -- content omitted, line counts are in the stat above. New blob: $newblob)"
      echo
      continue
    fi
    if (( total >= TOTAL_DIFF_CAP )); then
      echo "[remaining changed files omitted -- combined non-lockfile diff budget of $TOTAL_DIFF_CAP bytes reached; see stat above for the full file list]"
      break
    fi
    filediff="$(git -C "$HOLD" diff "$BASE_REF...$BRANCH" -- "$f" 2>/dev/null | head -c "$PER_FILE_DIFF_CAP")"
    [[ ${#filediff} -eq $PER_FILE_DIFF_CAP ]] && filediff="$filediff
[...diff for $f truncated at $PER_FILE_DIFF_CAP bytes...]"
    printf '%s\n\n' "$filediff"
    total=$((total + ${#filediff}))
  done
} > "$DIFF_TMP"
DIFF="$(cat "$DIFF_TMP")"

write_review() {
  local verdict="$1" reason="$2" extra="${3:-}"
  cat > "$REVIEW" <<EOF
# Review: $TASK ($BRANCH)

**Verdict:** $verdict
**Reviewed:** $(date -Is)

$reason
${extra:+
$extra}
EOF
}

reject() {
  local reason="$1"
  # REJECT already leaves the crew branch untouched in the hold (only
  # integration gets rolled back) -- but nothing pointed to it, so a future
  # redo had to manually discover it was cherry-pickable. Real voyage: a
  # partial-credit REJECT (most of the diff was fine, one piece wasn't) got
  # re-implemented from prose instead of cherry-picked, burning a wave that
  # didn't need to be burned. Pin the branch's current tip explicitly, in
  # both the review and the roster, so a redo doesn't have to go hunting.
  local salvage_sha salvage_note=""
  salvage_sha="$(git -C "$HOLD" rev-parse --short "$BRANCH" 2>/dev/null || true)"
  if [[ -n "$salvage_sha" ]]; then
    salvage_note="**Salvage:** crew branch \`$BRANCH\` retained at \`$salvage_sha\` — cherry-pickable for a redo (e.g. \`git -C .hold.git cherry-pick $salvage_sha\` from a fresh berth, or reference it directly in the redo order) if some of this attempt was actually correct."
    set_salvage "$salvage_sha"
  fi
  write_review "REJECT" "$reason" "$salvage_note"
  set_status "rejected"
  log "quartermaster-reject" "$TASK $BRANCH"
  echo "REJECT: $TASK ($BRANCH) — see $REVIEW"
  echo "$reason"
  exit 0
}

approve() {
  local reason="$1"
  write_review "APPROVE" "$reason"
  set_status "merged"
  log "quartermaster-approve" "$TASK $BRANCH"
  echo "APPROVE: $TASK ($BRANCH) merged into integration — see $REVIEW"
  echo "$reason"
  exit 0
}

# Serialize reviews: only one quartermaster pass may touch the integration
# worktree/branch at a time, since it's a single shared worktree (the same
# one ship/bin/telescope's dev server runs against) -- a concurrent second
# review would race the merge/reset below.
exec 8>"$BUS/.integration.lock"
flock 8

# --- integration branch + worktree: lazy-create, same convention as telescope ---
if git -C "$HOLD" show-ref --verify --quiet refs/heads/integration; then
  [[ -d "$INTWT" ]] || git -C "$HOLD" worktree add "$INTWT" integration >/dev/null
else
  git -C "$HOLD" branch integration main >/dev/null
  git -C "$HOLD" worktree add "$INTWT" integration >/dev/null
fi

[[ -z "$(git -C "$INTWT" status --porcelain)" ]] || {
  echo "quartermaster: $INTWT has uncommitted changes — clean it up before reviewing (never touched by this script otherwise)" >&2
  exit 1
}

PRE_MERGE_SHA="$(git -C "$INTWT" rev-parse HEAD)"

MERGE_LOG="$(mktemp)"
if ! git -C "$INTWT" merge --no-ff -m "merge: $TASK ($BRANCH)" "$BRANCH" >"$MERGE_LOG" 2>&1; then
  PRE_MERGE_SHORT="$(git -C "$INTWT" rev-parse --short "$PRE_MERGE_SHA")"
  git -C "$INTWT" merge --abort 2>/dev/null || true
  git -C "$INTWT" reset --hard "$PRE_MERGE_SHA" >/dev/null
  # shellcheck disable=SC2016  # single-quoted on purpose: this is a printf format string (%s placeholders), not meant to expand here
  printf -v CONFLICT_REASON 'Merge conflict bringing %s into integration (against %s). Needs a rebase onto current integration, or the conflicting order re-ordered/re-scoped. Merge log:\n\n```\n%s\n```' \
    "$BRANCH" "$PRE_MERGE_SHORT" "$(tail -c 4000 "$MERGE_LOG")"
  rm -f "$MERGE_LOG"
  reject "$CONFLICT_REASON"
fi
rm -f "$MERGE_LOG"

# --- dry-dock test: charter.md's "dry dock:" field under "## Test commands",
# same extraction idiom telescope already uses for its "command:"/"port:"
# fields. A failing (or unconfigured) dry-dock test is judged deterministically,
# never left to the LLM's discretion. ---
# charter.md's own template models the value with markdown backticks (e.g.
# "(fill in, e.g. `npm test`)"), and a real voyage copied that convention into
# a real value -- sed's extraction keeps the literal backticks, and
# `bash -c` below then treats them as command substitution, running the
# captured build/test's own stdout as a brand-new command and REJECTing
# clean crew work on a documentation defect, not a real failure. Strip one
# leading + one trailing backtick if both are present, same fix applied to
# telescope's identical extractor.
strip_backticks() {
  local s="$1"
  if [[ "$s" == \`*\` ]]; then
    s="${s#\`}"
    s="${s%\`}"
  fi
  printf '%s' "$s"
}

DRYDOCK_CMD=""
if [[ -f "$CHARTER_MD" ]]; then
  DRYDOCK_CMD="$(sed -n '/^## Test commands/,/^## /{/^- dry dock:/s/^- dry dock: *//p}' "$CHARTER_MD" | head -1)"
fi
[[ "$DRYDOCK_CMD" == \(* ]] && DRYDOCK_CMD=""
DRYDOCK_CMD="$(strip_backticks "$DRYDOCK_CMD")"

TEST_SUMMARY=""
if [[ -n "$DRYDOCK_CMD" ]]; then
  TEST_LOG="$(mktemp)"
  if (cd "$INTWT" && bash -c "$DRYDOCK_CMD") >"$TEST_LOG" 2>&1; then
    TEST_SUMMARY="dry-dock command \`$DRYDOCK_CMD\` exited 0 (pass). Tail of output:

\`\`\`
$(tail -c 8000 "$TEST_LOG")
\`\`\`"
  else
    RC=$?
    TEST_SUMMARY="dry-dock command \`$DRYDOCK_CMD\` exited $RC (FAIL). Tail of output:

\`\`\`
$(tail -c 8000 "$TEST_LOG")
\`\`\`"
    rm -f "$TEST_LOG"
    git -C "$INTWT" reset --hard "$PRE_MERGE_SHA" >/dev/null
    reject "Dry-dock test failed after merging $BRANCH into integration. $TEST_SUMMARY"
  fi
  rm -f "$TEST_LOG"
else
  TEST_SUMMARY="no dry-dock test command configured in charter.md's '## Test commands' section ('- dry dock: ...') — judge from the diff, report, and acceptance criteria alone."
fi

# --- LLM judgment: headless, --no-tools (pure text in/out — every fact it
# needs is already gathered above), same pick-model/SHIP_*_AGENT override
# pattern as muster and sail's bridge. Backend-aware like muster/sail: reads
# .ship/backend.json's `quartermaster` entry unless overridden. ---
if [[ -n "${SHIP_QUARTERMASTER_AGENT:-}" ]]; then
  REVIEW_AGENT="$SHIP_QUARTERMASTER_AGENT"
  # shellcheck disable=SC2016  # single-quoted on purpose: this is a printf format string, not meant to expand here
  QM_AUTH_SETUP='command -v unlock >/dev/null 2>&1 && eval "$(unlock)"'
else
  QM_BACKEND="$(backend_get "$DIR" quartermaster)"
  QM_AUTH_SETUP="$(backend_auth_setup "$QM_BACKEND" quartermaster)"
  if [[ "$(backend_field "$QM_BACKEND" '.prompt_mode')" == "agents_md" ]]; then
    # Codex has no --append-system-prompt equivalent -- same AGENTS.md-in-
    # cwd mechanism delegate-codex uses for crew, just in a throwaway temp
    # dir instead of a berth, since quartermaster isn't tied to any one
    # crew task's worktree.
    QM_PROMPT_DIR="$(mktemp -d)"
    cp "$SHIPYARD_DIR/ship/prompts/quartermaster.md" "$QM_PROMPT_DIR/AGENTS.md"
    REVIEW_AGENT="$(backend_render "$(backend_field "$QM_BACKEND" '.launch.quartermaster.cmd')" "PROMPT_DIR=$QM_PROMPT_DIR")"
  else
    REVIEW_AGENT="$(backend_render "$(backend_field "$QM_BACKEND" '.launch.quartermaster.cmd')" "PROMPT_FILE=$SHIPYARD_DIR/ship/prompts/quartermaster.md")"
  fi
fi

CTXFILE="$(mktemp)"
REVIEW_LOG="$(mktemp)"
{
  echo "# Work order"
  cat "$ORDER"
  echo
  echo "# Crew report"
  cat "$REPORT"
  echo
  echo "# Diff (branch $BRANCH vs. its fork point from $BASE_REF)"
  echo "Full content for source/config/test files; known lockfiles (package-lock.json"
  echo "etc.) are summarized as filename + new blob hash instead of full content --"
  echo "that's intentional, not missing evidence. The stat block up top lists every"
  echo "touched file, so cross-check completeness against it, not against the diff body."
  echo '```'
  printf '%s\n' "$DIFF"
  echo '```'
  echo
  echo "# Dry-dock test result"
  echo "$TEST_SUMMARY"
} > "$CTXFILE"

export SHIP_ROLE=quartermaster SHIP_CHARTER="$NAME" SHIP_NAME=quartermaster SHIP_TASK="$TASK"
eval "$QM_AUTH_SETUP"

VERDICT_OUT="$($REVIEW_AGENT "Decide APPROVE or REJECT for this crew work order, per your role contract." < "$CTXFILE" 2>"$REVIEW_LOG" || true)"

FIRST_LINE="$(printf '%s\n' "$VERDICT_OUT" | grep -m1 -E '^VERDICT:' || true)"
FEEDBACK="$(printf '%s\n' "$VERDICT_OUT" | sed -n '/^VERDICT:/,$p' | tail -n +2)"

case "$FIRST_LINE" in
  "VERDICT: APPROVE"*)
    approve "$FEEDBACK"
    ;;
  "VERDICT: REJECT"*)
    git -C "$INTWT" reset --hard "$PRE_MERGE_SHA" >/dev/null
    reject "$FEEDBACK"
    ;;
  *)
    git -C "$INTWT" reset --hard "$PRE_MERGE_SHA" >/dev/null
    reject "Quartermaster review agent gave no parseable verdict — treating as REJECT (a wrong APPROVE costs more than a cautious REJECT). Raw output:

\`\`\`
$(printf '%s' "$VERDICT_OUT" | head -c 4000)
\`\`\`"
    ;;
esac
