#!/usr/bin/env bash
# unlock — decrypt the strongbox and print export lines for the current shell
# usage: eval "$(unlock)"              # crew scope: model keys only (keys.env.age)
#        eval "$(unlock captain)"      # bridge/integration scope: adds captain.env.age
#        eval "$(unlock shipwright)"   # system-level scope: adds shipwright.env.age too
#
# Three compartments on purpose: crew agents need model keys to work, but must
# never hold push/publish credentials — "crew never push" (D10) is enforced
# here as a capability boundary, not just a line in crew.md. GH_TOKEN and any
# future publish credentials live only in captain.env.age. shipwright.env.age
# (ANTHROPIC_API_KEY) is scoped narrower still in a different dimension: it's
# for the one pane doing system-level work on ERDA-Will itself, not charter
# work — but that pane also needs push access, so shipwright scope is a
# strict superset of captain, not a sibling to it.
set -euo pipefail
SCOPE="${1:-crew}"
BOXDIR="${STRONGBOX_DIR:-$HOME/shipyard/strongbox}"
KEY="${AGE_KEY:-$HOME/.config/age/ship.key}"

# Best-effort: make sure cost-proxy is listening so pi's DeepInfra calls get
# real per-call cost logged (from DeepInfra's own usage.estimated_cost), not
# just pi's local price-table guess — models.json's baseUrl now points at it
# unconditionally, so every crew/captain window depends on it being up. Silent
# on stdout no matter what happens here: a stray byte would corrupt
# `eval "$(unlock)"`. Non-fatal too — a dead proxy must never block getting
# API keys into the shell; pi would just fail its own first call instead,
# which is the same failure shape as any other DeepInfra outage.
COST_PROXY_PORT="${COST_PROXY_PORT:-8790}"
if command -v cost-proxy >/dev/null 2>&1 && command -v curl >/dev/null 2>&1; then
  if ! curl -s -o /dev/null --max-time 1 "http://127.0.0.1:$COST_PROXY_PORT/healthz"; then
    nohup cost-proxy --port "$COST_PROXY_PORT" >>"$HOME/.cost-proxy.log" 2>&1 &
    disown
    # give it a moment to actually bind before this window's pi starts
    # sending it requests -- a fresh ship's very first sail/muster would
    # otherwise race the proxy's own startup.
    for _ in 1 2 3 4 5; do
      if curl -s -o /dev/null --max-time 1 "http://127.0.0.1:$COST_PROXY_PORT/healthz"; then
        break
      fi
      sleep 0.5
    done
  fi
fi

[[ -f "$KEY" ]] || { echo "echo 'age key not found: $KEY (drop your private key there)' >&2"; exit 1; }

case "$SCOPE" in
  crew)       FILES=("$BOXDIR/keys.env.age") ;;
  captain)    FILES=("$BOXDIR/keys.env.age" "$BOXDIR/captain.env.age") ;;
  shipwright) FILES=("$BOXDIR/keys.env.age" "$BOXDIR/captain.env.age" "$BOXDIR/shipwright.env.age") ;;
  *) echo "echo 'unlock: unknown scope: $SCOPE (crew|captain|shipwright)' >&2"; exit 1 ;;
esac

FOUND=0
for f in "${FILES[@]}"; do
  if [[ -f "$f" ]]; then
    # Strip a trailing \r before the export-prefix substitution. Secrets
    # encrypted via erda.ps1's `strongbox init` on Windows can end up with a
    # stray \r baked into the plaintext (PowerShell appends CRLF when piping
    # a string to a native process's stdin), which decrypts to a
    # plausible-looking, non-empty value with the right length +/- one
    # character -- and both PowerShell and even Windows git-bash's own tools
    # silently launder it away, so it only ever surfaces here, on a real
    # ship. A raw \r embedded in an exported env var is invisible in most
    # terminal output but breaks HTTP header values outright (GitHub
    # rejected it as "invalid", indistinguishable from a genuinely bad
    # token, until traced to this).
    age -d -i "$KEY" "$f" | sed -E 's/\r$//; s/^([A-Za-z_][A-Za-z0-9_]*)=/export \1=/'
    FOUND=1
  fi
done
[[ "$FOUND" -eq 1 ]] || { echo "echo 'strongbox: no compartments found in $BOXDIR' >&2"; exit 1; }
