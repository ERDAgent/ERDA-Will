#!/usr/bin/env bash
# sail — open (or reattach) the deck for a charter, filling in any role
# windows that got closed since the session was created. Safe to re-run any
# time: each of the 10 role windows (0-9) is checked and (re)created
# independently, so a window with live work in it (the bridge mid-
# conversation, a berth mid-review) is never touched -- only a genuinely
# missing window gets recreated. If the whole session is gone (e.g. the last
# window was closed, which tmux treats as closing the session), this
# rebuilds it from scratch, same as a first-time sail.
#
# Shipwright CO first landed at window 9 (appended after telescope, the
# only shape that's safe for sail's index-only gap-fill to re-run against an
# already-live deck without shifting anything). The Admiral then asked for
# it to sit directly after Shipwright CC instead, so windows 8 and 9 swapped
# meaning: 8 is now shipwright CO, 9 is telescope. On a brand-new sail this
# array produces that order directly. On a deck that already has both
# windows from before the swap, gap-fill alone won't reorder them (same
# reason appending was chosen originally -- it only fills genuinely missing
# indices) -- fix an existing deck with `tmux swap-window -s 8 -t 9` (or
# whatever ship-<charter> session), which trades the two windows' positions
# without touching either running pane/process. See HANDOFF.md §4bs.
# usage: sail <charter>
# One tmux session per charter: ship-<charter>, windows 0-9 = roles, 10+ = crew.
set -euo pipefail

FLEET="${FLEET:-$HOME/fleet}"
NAME="${1:?usage: sail <charter>}"
DIR="$FLEET/$NAME"
SES="ship-$NAME"
GLYPHS="${SHIP_GLYPHS:-1}"

[[ "$NAME" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]] || {
  echo "invalid charter name: '$NAME' (letters, digits, - and _ only)" >&2
  exit 1
}
[[ -d "$DIR/.ship" ]] || { echo "no such charter: $NAME (run: charter $NAME [git-url])" >&2; exit 1; }

g() { [[ "$GLYPHS" == "1" ]] && printf '%s ' "$1" || true; }

# resolve the real shipyard checkout even when invoked via the
# /usr/local/bin symlink fitout.sh sets up (readlink -f, not just
# dirname "${BASH_SOURCE[0]}", which would resolve to the symlink itself)
SHIPYARD_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../.." && pwd)"
# shellcheck source=ship/bin/backend-lib.sh
source "$SHIPYARD_DIR/ship/bin/backend-lib.sh"
CAPTAIN_PROMPT="$SHIPYARD_DIR/ship/prompts/captain.md"
# Captain default matches crew's model routing (D5) but runs interactively
# (no -p) with captain.md's role contract appended. Without this a bare
# `pi` has no idea it's supposed to plan/muster/gate rather than code
# directly -- found on a real Captain session: pi introduced itself as a
# generic coding assistant, no awareness of the role at all. Override with
# SHIP_CAPTAIN_AGENT (avoid a literal single-quote in the value -- it
# splices into a single-quoted bash -lc string below).
#
# Non-override case is backend-aware: resolved from ship/backends.json +
# this charter's .ship/backend.json (defaults to deepinfra, unchanged from
# before this feature existed). Reading the registry's `setup`/`cmd` fields
# via jq -- not writing them as bash source directly -- is what keeps the
# same deferred-evaluation trick the old hardcoded `\$(pick-model ...)` used:
# jq returns the literal text of the JSON string (dollar signs included), so
# it stays unexpanded until the window's own shell runs it later, exactly
# like before. Skipped entirely under SHIP_CAPTAIN_AGENT -- an explicit
# override means "run exactly this," no model-picking or registry lookup
# involved.
if [[ -n "${SHIP_CAPTAIN_AGENT:-}" ]]; then
  CAPTAIN_SETUP=""
  CAPTAIN_CMD="$SHIP_CAPTAIN_AGENT"
  # shellcheck disable=SC2016  # single-quoted on purpose: stays literal until spliced into BRIDGE_CMD and run by the window's own shell
  CAPTAIN_AUTH_SETUP='command -v unlock >/dev/null 2>&1 && eval "$(unlock captain)"'
  CAPTAIN_BINARY="pi"
else
  CAPTAIN_BACKEND="$(backend_get "$DIR" captain)"
  CAPTAIN_SETUP="$(backend_field "$CAPTAIN_BACKEND" '.launch.captain.setup')"
  CAPTAIN_AUTH_SETUP="$(backend_auth_setup "$CAPTAIN_BACKEND" captain)"
  CAPTAIN_BINARY="$(backend_field "$CAPTAIN_BACKEND" '.binary')"
  CAPTAIN_PROMPT_MODE="$(backend_field "$CAPTAIN_BACKEND" '.prompt_mode')"
  # A backend with a prompt addendum (delegate-claude.md/delegate-codex.md)
  # gets captain.md + that addendum concatenated into a charter-scoped,
  # regenerated-every-sail-run file -- keeps captain.md itself the one
  # shared, backend-agnostic contract instead of forking it per backend.
  CAPTAIN_ADDENDUM_REL="$(backend_field "$CAPTAIN_BACKEND" '.prompt_addendum // empty')"
  CAPTAIN_CONTENT_FILE="$CAPTAIN_PROMPT"
  if [[ -n "$CAPTAIN_ADDENDUM_REL" ]]; then
    CAPTAIN_ADDENDUM_PATH="$SHIPYARD_DIR/$CAPTAIN_ADDENDUM_REL"
    CAPTAIN_CONTENT_FILE="$DIR/.ship/captain-prompt-$CAPTAIN_BACKEND.md"
    { cat "$CAPTAIN_PROMPT"; echo; [[ -f "$CAPTAIN_ADDENDUM_PATH" ]] && cat "$CAPTAIN_ADDENDUM_PATH"; } > "$CAPTAIN_CONTENT_FILE"
  fi
  if [[ "$CAPTAIN_PROMPT_MODE" == "agents_md" ]]; then
    # Codex has no --append-system-prompt equivalent -- charter-scoped
    # AGENTS.md is the mechanism instead (same pattern as this repo's own
    # root AGENTS.md pointing Shipwright CO at shipwright.md). Regenerated
    # idempotently every sail run.
    { echo "<!-- auto-generated by sail -- do not hand-edit; regenerated every sail run -->"; cat "$CAPTAIN_CONTENT_FILE"; } > "$DIR/AGENTS.md"
    CAPTAIN_CMD="$(backend_field "$CAPTAIN_BACKEND" '.launch.captain.cmd')"
  else
    CAPTAIN_CMD="$(backend_render "$(backend_field "$CAPTAIN_BACKEND" '.launch.captain.cmd')" "PROMPT_FILE=$CAPTAIN_CONTENT_FILE")"
  fi
fi

# window 0 — bridge: the Captain (interactive pi/claude/codex, depending on
# the active backend), started at the charter root ($DIR), not a berth.
# captain.md tells the Captain to read charter.md and .ship/mission.md via
# plain relative paths, and the Captain never writes code itself (crew.md's
# job) -- so there's no berth to be in. Auth setup comes from the backend's
# own registry entry (unlock captain / claude's OAuth-token-or-API-key
# check / codex login status) instead of a single hardcoded `unlock
# captain` -- still always loads captain scope, just parameterized. Falls
# back to a plain shell if the active backend's binary or captain.md are
# missing.
# backend-watch is a no-op (exits immediately) when the active captain
# backend has no rate_limit_patterns configured -- true for deepinfra
# always, so this is cheap to start unconditionally rather than
# special-casing which backends need it. Same on-demand-background idiom
# `unlock` already uses for cost-proxy: started once, lazily, from here.
if command -v "$CAPTAIN_BINARY" >/dev/null 2>&1 && [[ -f "$CAPTAIN_PROMPT" ]]; then
  BRIDGE_CMD="bash -lc 'export SHIP_ROLE=captain SHIP_CHARTER=$NAME SHIP_NAME=captain SHIP_TASK=-; \
    $CAPTAIN_AUTH_SETUP; \
    backend-watch $NAME captain >/dev/null 2>&1 & disown; \
    echo \"[bridge] charter: $NAME — starting the Captain\"; ${CAPTAIN_SETUP}exec $CAPTAIN_CMD'"
else
  BRIDGE_CMD="bash -lc 'echo \"[bridge] charter: $NAME — $CAPTAIN_BINARY or captain.md not found, dropping to a shell\"; exec bash'"
fi

# window 1 — chartroom: Scuttlebutt on .ship/ (falls back to watching the bus)
if command -v fresh >/dev/null; then
  CHARTROOM_CMD="fresh mission.md"
else
  CHARTROOM_CMD="watch -t -n 5 'echo == mission ==; cat mission.md; echo; echo == orders ==; ls -1 orders 2>/dev/null; echo; echo == reports ==; ls -1 reports 2>/dev/null'"
fi

# window 7 — shipwright CC: system-level Claude Code, scoped to the shipyard
# repo itself ($SHIPYARD_DIR), never the charter -- this is one of the two
# panes that touch erda/ship/bin/fitout.sh etc., per CLAUDE.md's
# "Shipwrights" role (not part of the charter/crew system at all). Loads
# shipwright scope (crew + captain + its own ANTHROPIC_API_KEY) so it can
# both work and push changes back to ERDA-Will. Falls back to a plain shell
# if claude isn't installed, same pattern as the bridge window's pi
# fallback.
#
# --append-system-prompt takes inline text, not a path (checked `claude
# --help` directly rather than assuming it works like pi's flag of the same
# name, which does take a path) -- so `\$(cat ...)` is spliced in escaped,
# same deferred-evaluation trick as `\$(unlock shipwright)` below: it must
# read the file at the window's actual runtime, not sail's own generation
# time, both so $SHIPWRIGHT_PROMPT (resolved now, a real path) is correct
# and so a later edit to shipwright.md is picked up without regenerating
# this script.
SHIPWRIGHT_PROMPT="$SHIPYARD_DIR/ship/prompts/shipwright.md"
if command -v claude >/dev/null 2>&1; then
  SHIPWRIGHT_CMD="bash -lc 'command -v unlock >/dev/null 2>&1 && eval \"\$(unlock shipwright)\"; \
    echo \"[shipwright-cc] system-level session on ERDA-Will -- not this charter\"; \
    exec claude --append-system-prompt \"\$(cat $SHIPWRIGHT_PROMPT)\"'"
else
  SHIPWRIGHT_CMD="bash -lc 'echo \"[shipwright-cc] claude not found, dropping to a shell\"; exec bash'"
fi

# window 8 — shipwright CO: same role, Codex instead of Claude Code. Codex
# has no `--append-system-prompt` equivalent (checked `codex --help` and the
# shipped binary's own embedded base instructions directly, per this
# prompt's "ground the design in facts" rule -- no such flag exists); it
# auto-loads AGENTS.md from the cwd up through the repo root into the
# developer message instead, confirmed the same way. AGENTS.md (repo root)
# points at shipwright.md itself, so this window just needs the right cwd
# and a bare `codex` -- no flag-splicing to get the role contract in.
#
# Auth is deliberately NOT the strongbox: per
# docs/agentic-engineering-plan.md §4, Codex stays on the Admiral's own
# subscription via `codex login`, unlike Claude Code's API-key/D17 choice.
# `codex login status` exits nonzero when logged out (checked live on this
# ship) -- surfaced as a one-line reminder rather than left to a confusing
# failure inside Codex's own TUI. `unlock shipwright` is still loaded for
# GH_TOKEN (push credentials), same as CC -- ANTHROPIC_API_KEY just goes
# unused here.
if command -v codex >/dev/null 2>&1; then
  SHIPWRIGHT_CO_CMD="bash -lc 'command -v unlock >/dev/null 2>&1 && eval \"\$(unlock shipwright)\"; \
    echo \"[shipwright-co] system-level session on ERDA-Will -- not this charter\"; \
    codex login status >/dev/null 2>&1 || echo \"[shipwright-co] not logged in -- run: codex login (or: codex login --device-auth over SSH)\"; \
    exec codex'"
else
  SHIPWRIGHT_CO_CMD="bash -lc 'echo \"[shipwright-co] codex not found, dropping to a shell\"; exec bash'"
fi

# window 6 — engine-room
ENGINE_CMD="top"; command -v htop >/dev/null && ENGINE_CMD="htop"

# One source of truth for both a from-scratch sail and gap-filling an
# already-open deck -- an accidentally-closed window previously stayed
# closed forever, since sail only ever built the whole session in one shot,
# and only when the session didn't exist at all yet.
WINDOW_DIRS=(
  "$DIR"          "$DIR/.ship"    "$DIR/.ship"    "$DIR/.ship"
  "$DIR"          "$DIR/.ship"    "$DIR"          "$SHIPYARD_DIR"  "$SHIPYARD_DIR"          "$DIR"
)
# Role glyphs are one space away from their label via g()'s own trailing
# space, except the six "person + ZWJ + role" compound emoji (Bridge, First
# Mate, Bosun, Purser, Shipwright CC, Shipwright CO) -- these are 3-codepoint
# sequences joined by a zero-width joiner, which not every terminal font
# renders as one glued glyph the way it does simple single-codepoint emoji
# (Chartroom, Quartermaster, Telescope, crew's own 👷). An inconsistent
# render can visibly eat the following space, so those six get one extra
# literal space as a buffer -- can't fix a font's own ZWJ support from here,
# only make the gap more robust against it.
WINDOW_NAMES=(
  "$(g 🧑‍✈) Bridge"         "$(g 🗺) Chartroom"      "$(g 🧑‍🔬) First Mate"    "$(g 🧑‍🔧) Bosun"
  "$(g 📋) Quartermaster"    "$(g 🧑‍💼) Purser"       "$(g ⚙️) Engine Room"      "$(g 🧑‍🏭) Shipwright CC" "$(g 🧑‍🏭) Shipwright CO"
  "$(g 🔭) Telescope"
)
WINDOW_CMDS=(
  "$BRIDGE_CMD"
  "$CHARTROOM_CMD"
  "watch -t -n 5 'if [ -f mission-critique.md ]; then cat mission-critique.md; else echo \"[first-mate] no critique yet -- the Captain runs /critique itself as part of PLAN, or run it by hand once a mission has orders\"; fi'"
  "bash -lc 'watch -t -n 5 bosun'"
  "watch -t -n 10 'echo \"📋 Quartermaster\"; echo; echo == branches ==; git -C .hold.git branch -a; echo; echo == recent ==; git -C .hold.git log --oneline --all -n 10'"
  "bash -lc 'watch -t -n 5 purser-totals'"
  "$ENGINE_CMD"
  "$SHIPWRIGHT_CMD"
  "$SHIPWRIGHT_CO_CMD"
  "bash -lc 'exec telescope $NAME'"
)

NEW_SESSION=0
if ! tmux has-session -t "=$SES" 2>/dev/null; then
  NEW_SESSION=1
  tmux new-session -d -s "$SES" -c "${WINDOW_DIRS[0]}" -n "${WINDOW_NAMES[0]}" "${WINDOW_CMDS[0]}"
fi

for i in "${!WINDOW_CMDS[@]}"; do
  [[ "$NEW_SESSION" -eq 1 && "$i" -eq 0 ]] && continue   # just created above
  if ! tmux list-windows -t "=$SES" -F '#I' 2>/dev/null | grep -qx "$i"; then
    echo "sail: window $i (${WINDOW_NAMES[$i]}) was missing -- reopening it"
    tmux new-window -t "$SES:$i" -c "${WINDOW_DIRS[$i]}" -n "${WINDOW_NAMES[$i]}" "${WINDOW_CMDS[$i]}"
  fi
done

[[ "$NEW_SESSION" -eq 1 ]] && tmux select-window -t "$SES:0"

# attach (or switch, if already inside tmux). SHIP_NO_ATTACH=1 for scripts/CI.
if [[ "${SHIP_NO_ATTACH:-0}" == "1" ]]; then
  echo "deck open: $SES (not attaching)"
elif [[ -n "${TMUX:-}" ]]; then
  exec tmux switch-client -t "$SES"
else
  exec tmux attach -t "$SES"
fi
