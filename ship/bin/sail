#!/usr/bin/env bash
# sail — open (or reattach) the deck for a charter, filling in any role
# windows that got closed since the session was created. Safe to re-run any
# time: each of the 9 role windows (0-8) is checked and (re)created
# independently, so a window with live work in it (the bridge mid-
# conversation, a berth mid-review) is never touched -- only a genuinely
# missing window gets recreated. If the whole session is gone (e.g. the last
# window was closed, which tmux treats as closing the session), this
# rebuilds it from scratch, same as a first-time sail.
# usage: sail <charter>
# One tmux session per charter: ship-<charter>, windows 0-8 = roles, 9+ = crew.
set -euo pipefail

FLEET="${FLEET:-$HOME/fleet}"
NAME="${1:?usage: sail <charter>}"
DIR="$FLEET/$NAME"
SES="ship-$NAME"
GLYPHS="${SHIP_GLYPHS:-1}"

[[ "$NAME" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]] || {
  echo "invalid charter name: '$NAME' (letters, digits, - and _ only)" >&2
  exit 1
}
[[ -d "$DIR/.ship" ]] || { echo "no such charter: $NAME (run: charter $NAME [git-url])" >&2; exit 1; }

g() { [[ "$GLYPHS" == "1" ]] && printf '%s ' "$1" || true; }

# resolve the real shipyard checkout even when invoked via the
# /usr/local/bin symlink fitout.sh sets up (readlink -f, not just
# dirname "${BASH_SOURCE[0]}", which would resolve to the symlink itself)
SHIPYARD_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../.." && pwd)"
CAPTAIN_PROMPT="$SHIPYARD_DIR/ship/prompts/captain.md"
# Captain default matches crew's model routing (D5) but runs interactively
# (no -p) with captain.md's role contract appended. Without this a bare
# `pi` has no idea it's supposed to plan/muster/gate rather than code
# directly -- found on a real Captain session: pi introduced itself as a
# generic coding assistant, no awareness of the role at all. Override with
# SHIP_CAPTAIN_AGENT (avoid a literal single-quote in the value -- it
# splices into a single-quoted bash -lc string below).
#
# CAPTAIN_SETUP resolves the model via `pick-model` (health-checks
# ship/models-priority.txt against a real DeepInfra call and picks the first
# one that responds) at the bridge window's actual start time -- not here,
# since DEEPINFRA_API_KEY isn't loaded into this outer, not-yet-unlocked
# shell yet. The `\$` escaping below is deliberate: it must stay literal
# text (for the window's own shell to evaluate later), not expand now.
# Skipped entirely under SHIP_CAPTAIN_AGENT, same as before -- an explicit
# override means "run exactly this," no model-picking involved.
if [[ -n "${SHIP_CAPTAIN_AGENT:-}" ]]; then
  CAPTAIN_SETUP=""
  CAPTAIN_CMD="$SHIP_CAPTAIN_AGENT"
else
  CAPTAIN_SETUP="MODEL=\$(pick-model 2>&2 || echo zai-org/GLM-5.2); "
  CAPTAIN_CMD="pi --provider deepinfra --model \"\$MODEL\" --thinking high --append-system-prompt $CAPTAIN_PROMPT"
fi

# window 0 — bridge: the Captain (interactive pi), started at the charter
# root ($DIR), not a berth. captain.md tells the Captain to read charter.md
# and .ship/mission.md via plain relative paths, and the Captain never
# writes code itself (crew.md's job) -- so there's no berth to be in. Loads
# the strongbox at CAPTAIN scope (model keys + captain.env.age: GH_TOKEN
# etc.) -- the bridge is the one window entitled to push credentials. Crew
# windows load crew scope via muster's plain `unlock`. Falls back to a
# plain shell if pi or captain.md are missing.
if command -v pi >/dev/null 2>&1 && [[ -f "$CAPTAIN_PROMPT" ]]; then
  BRIDGE_CMD="bash -lc 'export SHIP_ROLE=captain SHIP_CHARTER=$NAME SHIP_NAME=captain SHIP_TASK=-; \
    command -v unlock >/dev/null 2>&1 && eval \"\$(unlock captain)\"; \
    echo \"[bridge] charter: $NAME — starting the Captain\"; ${CAPTAIN_SETUP}exec $CAPTAIN_CMD'"
else
  BRIDGE_CMD="bash -lc 'echo \"[bridge] charter: $NAME — pi or captain.md not found, dropping to a shell\"; exec bash'"
fi

# window 1 — chartroom: Scuttlebutt on .ship/ (falls back to watching the bus)
if command -v fresh >/dev/null; then
  CHARTROOM_CMD="fresh mission.md"
else
  CHARTROOM_CMD="watch -t -n 5 'echo == mission ==; cat mission.md; echo; echo == orders ==; ls -1 orders 2>/dev/null; echo; echo == reports ==; ls -1 reports 2>/dev/null'"
fi

# window 7 — shipwright: system-level Claude Code, scoped to the shipyard
# repo itself ($SHIPYARD_DIR), never the charter -- this is the one pane
# that touches erda/ship/bin/fitout.sh etc., per CLAUDE.md's "Shipwrights"
# role (not part of the charter/crew system at all). Loads shipwright scope
# (crew + captain + its own ANTHROPIC_API_KEY) so it can both work and push
# changes back to ERDA-Will. Falls back to a plain shell if claude isn't
# installed, same pattern as the bridge window's pi fallback.
#
# --append-system-prompt takes inline text, not a path (checked `claude
# --help` directly rather than assuming it works like pi's flag of the same
# name, which does take a path) -- so `\$(cat ...)` is spliced in escaped,
# same deferred-evaluation trick as `\$(unlock shipwright)` below: it must
# read the file at the window's actual runtime, not sail's own generation
# time, both so $SHIPWRIGHT_PROMPT (resolved now, a real path) is correct
# and so a later edit to shipwright.md is picked up without regenerating
# this script.
SHIPWRIGHT_PROMPT="$SHIPYARD_DIR/ship/prompts/shipwright.md"
if command -v claude >/dev/null 2>&1; then
  SHIPWRIGHT_CMD="bash -lc 'command -v unlock >/dev/null 2>&1 && eval \"\$(unlock shipwright)\"; \
    echo \"[shipwright] system-level session on ERDA-Will -- not this charter\"; \
    exec claude --append-system-prompt \"\$(cat $SHIPWRIGHT_PROMPT)\"'"
else
  SHIPWRIGHT_CMD="bash -lc 'echo \"[shipwright] claude not found, dropping to a shell\"; exec bash'"
fi

# window 6 — engine-room
ENGINE_CMD="top"; command -v htop >/dev/null && ENGINE_CMD="htop"

# One source of truth for both a from-scratch sail and gap-filling an
# already-open deck -- an accidentally-closed window previously stayed
# closed forever, since sail only ever built the whole session in one shot,
# and only when the session didn't exist at all yet.
WINDOW_DIRS=(
  "$DIR"          "$DIR/.ship"    "$DIR/.ship"    "$DIR/.ship"
  "$DIR"          "$DIR/.ship"    "$DIR"          "$SHIPYARD_DIR"  "$DIR"
)
WINDOW_NAMES=(
  "$(g ⚓)bridge"       "$(g 🗺)chartroom"     "$(g 🧭)first-mate"   "$(g 📣)bosun"
  "$(g ⚖)quartermaster" "$(g 🪙)purser"        "$(g ⚙)engine-room"  "$(g 🔨)shipwright" "$(g 🔭)telescope"
)
WINDOW_CMDS=(
  "$BRIDGE_CMD"
  "$CHARTROOM_CMD"
  "bash -lc 'echo \"[first-mate] plan critique station — review mission.md before approving muster\"; exec bash'"
  "watch -t -n 5 'echo == roster ==; jq -r \".[] | [.name,.task,.status,.branch] | @tsv\" roster.json 2>/dev/null || cat roster.json; echo; echo == last events ==; tail -n 8 log/events.log'"
  "watch -t -n 10 'echo == branches ==; git -C .hold.git branch -a; echo; echo == recent ==; git -C .hold.git log --oneline --all -n 10'"
  "bash -lc 'watch -t -n 5 purser-totals'"
  "$ENGINE_CMD"
  "$SHIPWRIGHT_CMD"
  "bash -lc 'exec telescope $NAME'"
)

NEW_SESSION=0
if ! tmux has-session -t "=$SES" 2>/dev/null; then
  NEW_SESSION=1
  tmux new-session -d -s "$SES" -c "${WINDOW_DIRS[0]}" -n "${WINDOW_NAMES[0]}" "${WINDOW_CMDS[0]}"
fi

for i in "${!WINDOW_CMDS[@]}"; do
  [[ "$NEW_SESSION" -eq 1 && "$i" -eq 0 ]] && continue   # just created above
  if ! tmux list-windows -t "=$SES" -F '#I' 2>/dev/null | grep -qx "$i"; then
    echo "sail: window $i (${WINDOW_NAMES[$i]}) was missing -- reopening it"
    tmux new-window -t "$SES:$i" -c "${WINDOW_DIRS[$i]}" -n "${WINDOW_NAMES[$i]}" "${WINDOW_CMDS[$i]}"
  fi
done

[[ "$NEW_SESSION" -eq 1 ]] && tmux select-window -t "$SES:0"

# attach (or switch, if already inside tmux). SHIP_NO_ATTACH=1 for scripts/CI.
if [[ "${SHIP_NO_ATTACH:-0}" == "1" ]]; then
  echo "deck open: $SES (not attaching)"
elif [[ -n "${TMUX:-}" ]]; then
  exec tmux switch-client -t "$SES"
else
  exec tmux attach -t "$SES"
fi
