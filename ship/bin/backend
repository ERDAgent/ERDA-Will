#!/usr/bin/env bash
# backend — show/set which backend (deepinfra/claude/codex) powers a ship role
# usage: backend --list                          list registered backends
#        backend <charter>                       show all roles' active backend
#        backend <charter> <role>                 show one role's active backend
#        backend <charter> <role> <backend-name>  set it (validated against the registry)
#
# Switching takes effect on next spawn only (a running Bridge/crew window
# keeps running on its current backend until restarted) -- see
# docs/backend-verification-notes.md and HANDOFF.md for why this isn't a
# live hot-swap.
set -euo pipefail

SHIPYARD_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../.." && pwd)"
# shellcheck source=ship/bin/backend-lib.sh
source "$SHIPYARD_DIR/ship/bin/backend-lib.sh"

FLEET="${FLEET:-$HOME/fleet}"
USAGE="usage: backend --list | backend <charter> [role] [backend-name]"
ROLES=(captain crew first-mate quartermaster)

if [[ "${1:-}" == "--list" ]]; then
  jq -r 'to_entries[] | "\(.key)\t\(.value.label)\t(delegate: \(.value.delegate))"' "$BACKENDS_REGISTRY" \
    | column -t -s $'\t'
  exit 0
fi

# doctor: live auth-readiness check, run ON the ship (complements host-side
# `erda doctor`, which can't see codex login state or reach this ship at
# all). Charter arg is optional and only adds a per-role report -- the
# backends themselves aren't per-charter, so `backend doctor` alone already
# tells you everything about what's usable right now.
if [[ "${1:-}" == "doctor" ]]; then
  shift
  echo "backend doctor: checking auth for each registered backend..."
  ALL_OK=1
  while IFS= read -r b; do
    backend_check_auth "$b" || ALL_OK=0
  done < <(backend_names)
  if [[ -n "${1:-}" ]]; then
    CNAME="$1"
    CDIR="$FLEET/$CNAME"
    if [[ -d "$CDIR/.ship" ]]; then
      echo
      echo "charter '$CNAME' -- active backend per role:"
      for r in "${ROLES[@]}"; do
        cb="$(backend_get "$CDIR" "$r")"
        printf '  %-14s %s\n' "$r" "$cb"
      done
    else
      echo "backend doctor: no such charter: $CNAME (skipping per-role report)" >&2
      ALL_OK=0
    fi
  fi
  echo
  if [[ "$ALL_OK" -eq 1 ]]; then
    echo "backend doctor: all checks passed"
    exit 0
  else
    exit 1
  fi
fi

NAME="${1:?$USAGE}"
DIR="$FLEET/$NAME"
[[ "$NAME" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]] || {
  echo "invalid charter name: '$NAME' (letters, digits, - and _ only)" >&2
  exit 1
}
[[ -d "$DIR/.ship" ]] || { echo "no such charter: $NAME (run: charter $NAME)" >&2; exit 1; }
STATE="$(backend_state_path "$DIR")"
[[ -f "$STATE" ]] || printf '{"captain":"deepinfra","crew":"deepinfra","first-mate":"deepinfra","quartermaster":"deepinfra"}\n' > "$STATE"

ROLE="${2:-}"
NEWBACKEND="${3:-}"

if [[ -z "$ROLE" ]]; then
  jq -r 'to_entries[] | "\(.key)\t\(.value)"' "$STATE" | column -t -s $'\t'
  exit 0
fi

case " ${ROLES[*]} " in
  *" $ROLE "*) ;;
  *) echo "unknown role: '$ROLE' (known: ${ROLES[*]})" >&2; exit 1 ;;
esac

if [[ -z "$NEWBACKEND" ]]; then
  jq -r --arg r "$ROLE" '.[$r] // "deepinfra"' "$STATE"
  exit 0
fi

backend_exists "$NEWBACKEND" || {
  echo "unknown backend: '$NEWBACKEND' (known: $(backend_names | tr '\n' ' '))" >&2
  exit 1
}

OLD="$(jq -r --arg r "$ROLE" '.[$r] // "deepinfra"' "$STATE")"
(
  flock 9
  TMPJ="$(mktemp)"
  jq --arg r "$ROLE" --arg b "$NEWBACKEND" '.[$r] = $b' "$STATE" > "$TMPJ" && mv "$TMPJ" "$STATE"
) 9>"$DIR/.ship/.backend.lock"
printf '%s\t%s\t%s\n' "$(date -Is)" "backend-switch" "$ROLE $OLD -> $NEWBACKEND" >> "$DIR/.ship/log/events.log"
echo "backend: $NAME/$ROLE now $NEWBACKEND (was $OLD)"

# Auto-check the new backend's auth right here rather than waiting for it to
# fail at spawn time -- catches "switched to claude but never ran claude
# setup-token" immediately. Non-blocking on purpose: the switch already
# happened (auth may get fixed after the fact, or a network blip shouldn't
# undo a deliberate switch), this is a warning, not a gate.
echo "backend: verifying $NEWBACKEND auth..."
backend_check_auth "$NEWBACKEND" || echo "backend: switched anyway -- fix the above before the next $ROLE spawn/restart, or it'll fail there instead" >&2

# Switching is next-spawn-only -- a live window keeps running its current
# backend until restarted, since decision 2 (see HANDOFF.md) rules out a
# mid-conversation hot-swap/context transplant.
case "$ROLE" in
  captain)
    echo "note: the Bridge window (0) is running under '$OLD' until restarted:"
    echo "  tmux kill-window -t ship-$NAME:0 && sail $NAME"
    ;;
  *)
    echo "note: takes effect on the next $ROLE invocation -- nothing currently running changes"
    ;;
esac
