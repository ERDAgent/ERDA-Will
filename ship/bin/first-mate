#!/usr/bin/env bash
# first-mate — plan critique: a second pair of eyes on the Captain's
# mission.md + current work orders, before the Admiral approves muster.
# usage: first-mate <charter>
#
# Advisory only -- never blocks anything, never touches git. Deterministic
# checks (scope conflicts between orders' declared file ownership, no-touch
# path violations, missing budget/acceptance-criteria fields) are computed
# by this script and are ground truth; a headless, --no-tools LLM pass
# (ship/prompts/first-mate.md) adds qualitative judgment on top (is the
# decomposition sensible, are budgets proportionate) without ever being
# allowed to contradict the mechanical findings. Same split as
# ship/bin/quartermaster: deterministic gathering, LLM judgment, nothing for
# a stray tool call to break because there are no tools.
#
# Writes .ship/mission-critique.md (sail's window 2 shows this live) and
# prints a summary to stdout.
set -euo pipefail

SHIPYARD_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../.." && pwd)"
# shellcheck source=ship/bin/backend-lib.sh
source "$SHIPYARD_DIR/ship/bin/backend-lib.sh"
FLEET="${FLEET:-$HOME/fleet}"
NAME="${1:?usage: first-mate <charter>}"

[[ "$NAME" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]] || {
  echo "invalid charter name: '$NAME' (letters, digits, - and _ only)" >&2
  exit 1
}

DIR="$FLEET/$NAME"
BUS="$DIR/.ship"
CHARTER_MD="$DIR/charter.md"
MISSION="$BUS/mission.md"
CRITIQUE="$BUS/mission-critique.md"

[[ -d "$BUS" ]] || { echo "first-mate: no such charter: $NAME" >&2; exit 1; }

mapfile -t ORDERS < <(compgen -G "$BUS/orders/*.md" || true)
[[ "${#ORDERS[@]}" -gt 0 ]] || {
  echo "first-mate: no orders in $BUS/orders/ yet -- nothing to critique" >&2
  exit 1
}

# "# Work order: <TASK-ID> — <title>" (order-template.md's own header,
# confirmed against real Captain-written orders in earlier drills) -- split
# on the em dash specifically, not any hyphen, since task ids themselves
# often contain hyphens (e.g. "T-014").
order_task_id() {
  grep -m1 '^# Work order:' "$1" | sed -E 's/^# Work order:[[:space:]]*//' | sed -E 's/[[:space:]]*—.*$//'
}

# "## Scope — files you may touch\n- path\n- path\n(Everything else...)"
order_scope_files() {
  sed -n '/^## Scope/,/^## /{/^- /s/^- *//p}' "$1"
}

# same greppable-field convention bosun's budget_for already uses
budget_for() {
  local order="$1" turns tokens
  turns="$(grep -oE 'max turns:[[:space:]]*[0-9]+' "$order" | head -1 | grep -oE '[0-9]+' || true)"
  tokens="$(grep -oE 'max output tokens:[[:space:]]*[0-9]+' "$order" | head -1 | grep -oE '[0-9]+' || true)"
  echo "${turns:-0} ${tokens:-0}"
}

notouch_paths() {
  [[ -f "$CHARTER_MD" ]] || return 0
  sed -n '/^## No-touch paths/,/^## /{/^- /s/^- *//p}' "$CHARTER_MD" | grep -v '^(' || true
}

ROSTER="$BUS/roster.json"
task_status() {
  [[ -f "$ROSTER" ]] || { echo ""; return; }
  jq -r --arg t "$1" '[.[] | select(.task==$t)][0].status // empty' "$ROSTER" 2>/dev/null
}

PAIRS="$(mktemp)"

for order in "${ORDERS[@]}"; do
  task="$(order_task_id "$order")"
  [[ -z "$task" ]] && task="(unknown task id in $(basename "$order"))"
  # Skip orders whose roster status is already terminal (merged/rejected) --
  # their scope claim is history, not a live conflict. A real voyage hit
  # this as a real false positive: a later legitimate re-brief of the same
  # file (e.g. a "-F" follow-up order re-touching a file its own already-
  # merged predecessor also listed) flagged SCOPE CONFLICT every time even
  # though the Mate's own LLM pass correctly judged it benign. Still count
  # "working"/"sos" (not yet resolved) and not-yet-mustered orders (no
  # roster entry at all) -- those really can collide.
  status="$(task_status "$task")"
  case "$status" in
    merged|rejected) continue ;;
  esac
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    printf '%s\t%s\n' "$f" "$task" >> "$PAIRS"
  done < <(order_scope_files "$order")
done

FINDINGS=()

# --- scope conflicts: a file claimed by more than one order ---
sort -u -o "$PAIRS" "$PAIRS"
OVERLAP_FILES="$(cut -f1 "$PAIRS" | sort | uniq -d || true)"
if [[ -n "$OVERLAP_FILES" ]]; then
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    TASKS="$(awk -F'\t' -v file="$f" '$1==file {print $2}' "$PAIRS" | paste -sd, -)"
    FINDINGS+=("SCOPE CONFLICT: '$f' is claimed by more than one order: $TASKS")
  done <<< "$OVERLAP_FILES"
fi

# --- no-touch path violations ---
NOTOUCH="$(notouch_paths)"
if [[ -n "$NOTOUCH" ]]; then
  while IFS= read -r ntp; do
    [[ -z "$ntp" ]] && continue
    # directory-style no-touch entries are often written with a trailing
    # slash (e.g. "deploy/") -- strip it before building the glob, or
    # "deploy/"/* becomes the literal pattern "deploy//*", which never
    # matches a real path like "deploy/config.yaml" (single slash). Found
    # by First Mate's own LLM pass catching a violation this check missed.
    ntp_stripped="${ntp%/}"
    while IFS=$'\t' read -r f task; do
      [[ -z "$f" ]] && continue
      if [[ "$f" == "$ntp" || "$f" == "$ntp_stripped"/* ]]; then
        FINDINGS+=("NO-TOUCH VIOLATION: order $task's scope includes '$f', matching charter.md's no-touch path '$ntp'")
      fi
    done < "$PAIRS"
  done <<< "$NOTOUCH"
fi

# --- missing budget / acceptance criteria, per order ---
for order in "${ORDERS[@]}"; do
  task="$(order_task_id "$order")"
  read -r MAX_TURNS MAX_TOKENS <<< "$(budget_for "$order")"
  if [[ "$MAX_TURNS" -eq 0 && "$MAX_TOKENS" -eq 0 ]]; then
    FINDINGS+=("$task: no parseable Budget (max turns / max output tokens) declared")
  fi
  if ! grep -qE '^\s*- \[ \]' "$order"; then
    FINDINGS+=("$task: no acceptance-criteria checkboxes found")
  fi
done

FINDINGS_TEXT="(none — no scope conflicts, no no-touch violations, every order has a parseable budget and at least one acceptance criterion)"
if [[ "${#FINDINGS[@]}" -gt 0 ]]; then
  FINDINGS_TEXT="$(printf -- '- %s\n' "${FINDINGS[@]}")"
fi

# --- LLM judgment: headless, --no-tools, same pattern as quartermaster.
# Backend-aware like muster/sail/quartermaster: reads .ship/backend.json's
# `first-mate` entry unless overridden. ---
FM_PROMPT_DIR=""
if [[ -n "${SHIP_FIRSTMATE_AGENT:-}" ]]; then
  CRITIQUE_AGENT="$SHIP_FIRSTMATE_AGENT"
  # shellcheck disable=SC2016  # single-quoted on purpose: this is a printf format string, not meant to expand here
  FM_AUTH_SETUP='command -v unlock >/dev/null 2>&1 && eval "$(unlock)"'
else
  FM_BACKEND="$(backend_get "$DIR" first-mate)"
  FM_AUTH_SETUP="$(backend_auth_setup "$FM_BACKEND" first-mate)"
  if [[ "$(backend_field "$FM_BACKEND" '.prompt_mode')" == "agents_md" ]]; then
    # Codex has no --append-system-prompt equivalent -- same AGENTS.md-in-
    # cwd mechanism delegate-codex uses for crew, just in a throwaway temp
    # dir instead of a berth.
    FM_PROMPT_DIR="$(mktemp -d)"
    cp "$SHIPYARD_DIR/ship/prompts/first-mate.md" "$FM_PROMPT_DIR/AGENTS.md"
    CRITIQUE_AGENT="$(backend_render "$(backend_field "$FM_BACKEND" '.launch["first-mate"].cmd')" "PROMPT_DIR=$FM_PROMPT_DIR")"
  else
    CRITIQUE_AGENT="$(backend_render "$(backend_field "$FM_BACKEND" '.launch["first-mate"].cmd')" "PROMPT_FILE=$SHIPYARD_DIR/ship/prompts/first-mate.md")"
  fi
fi

CTXFILE="$(mktemp)"
trap 'rm -f "$PAIRS" "$CTXFILE"; [[ -n "$FM_PROMPT_DIR" ]] && rm -rf "$FM_PROMPT_DIR"' EXIT
{
  echo "# Mission"
  if [[ -f "$MISSION" ]]; then cat "$MISSION"; else echo "(no mission.md found)"; fi
  echo
  echo "# Work orders"
  for order in "${ORDERS[@]}"; do
    echo "## File: $(basename "$order")"
    cat "$order"
    echo
  done
  echo "# charter.md no-touch paths"
  if [[ -n "$NOTOUCH" ]]; then printf '%s\n' "$NOTOUCH"; else echo "(none declared)"; fi
  echo
  echo "# Deterministic findings (already confirmed mechanically -- ground truth)"
  echo "$FINDINGS_TEXT"
} > "$CTXFILE"

export SHIP_ROLE=first-mate SHIP_CHARTER="$NAME" SHIP_NAME=first-mate SHIP_TASK=-
eval "$FM_AUTH_SETUP"

# CRITIQUE_AGENT is a literal, unevaluated command string (see the matching
# comment in ship/bin/quartermaster) -- word-splitting it directly would
# leave its embedded `--append-system-prompt "$(cat ...)"` unevaluated, so
# the critique agent never receives its role contract. `eval` re-parses the
# whole string as shell syntax so the substitution actually runs.
CRITIQUE_OUT="$(eval "$CRITIQUE_AGENT \"Give your critique of this mission's decomposition, per your role contract.\"" < "$CTXFILE" 2>/tmp/first-mate-"$NAME".log || true)"

FIRST_LINE="$(printf '%s\n' "$CRITIQUE_OUT" | grep -m1 -E '^STATUS:' || true)"
case "$FIRST_LINE" in
  "STATUS: CLEAR"*|"STATUS: CONCERNS"*) LLM_SECTION="$CRITIQUE_OUT" ;;
  *) LLM_SECTION="STATUS: CONCERNS
First Mate's qualitative pass returned no parseable STATUS line -- treat this as
\"couldn't get a second opinion this time,\" not as a clean bill of health. Raw output:

$(printf '%s' "$CRITIQUE_OUT" | head -c 4000)" ;;
esac

cat > "$CRITIQUE" <<EOF
# First Mate — plan critique

**Reviewed:** $(date -Is)

## Deterministic findings
$FINDINGS_TEXT

## First Mate's read
$LLM_SECTION
EOF

echo "First Mate critique written to $CRITIQUE"
echo
cat "$CRITIQUE"
