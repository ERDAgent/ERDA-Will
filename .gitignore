.DS_Store

# Neptune's narrow permission lockdown (see neptune/README.md) belongs only on
# the Admiral's own host machine, never on a ship -- keeping it untracked is what
# makes that true even though .claude/settings.json is a plain git clone away
# on every ship.
.claude/settings.local.json

# strongbox: only the encrypted bundle is ever committed
strongbox/*.key
strongbox/keys.env
!strongbox/keys.env.age

# scuttlebutt/types/*.d.ts are auto-generated BY fresh itself on every run
# (confirmed live: content is stable, mtime updates every launch) -- Fresh's
# own equivalent of node_modules, not something to track. Created the first
# time `fresh` runs on a given ship; scuttlebutt/tsconfig.json's "files" list
# needs them present locally to typecheck, same caveat as any npm package's
# generated .d.ts output.
scuttlebutt/types/
